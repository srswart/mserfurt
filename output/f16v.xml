<?xml version='1.0' encoding='utf-8'?>
<PcGts xmlns="http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15 http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15/pagecontent.xsd"><Metadata><Creator>xl-export</Creator><Created>2026-03-19T00:00:00Z</Created><LastChange>2026-03-19T00:00:00Z</LastChange></Metadata><Page imageFilename="" imageWidth="1000" imageHeight="1000"><TextRegion id="r1" custom="type:paragraph"><Coords points="0,0 1000,0 1000,1000 0,1000" /><TextLine id="l1" custom="register:de"><Coords points="0,0 1000,0 1000,38 0,38" /><Baseline points="0,36 1000,36" /><TextEquiv index="0"><Unicode>One of the pages slipped from the stack. It fell face-up on</Unicode></TextEquiv></TextLine><TextLine id="l2" custom="register:de"><Coords points="0,38 1000,38 1000,76 0,76" /><Baseline points="0,74 1000,74" /><TextEquiv index="0"><Unicode>the floor between Hans and the press.</Unicode></TextEquiv></TextLine><TextLine id="l3" custom="register:de"><Coords points="0,76 1000,76 1000,114 0,114" /><Baseline points="0,112 1000,112" /><TextEquiv index="0"><Unicode>I picked it up.</Unicode></TextEquiv></TextLine><TextLine id="l4" custom="register:de"><Coords points="0,114 1000,114 1000,152 0,152" /><Baseline points="0,150 1000,150" /><TextEquiv index="0"><Unicode>I read the passage.</Unicode></TextEquiv></TextLine><TextLine id="l5" custom="register:verbatim_mhg"><Coords points="0,152 1000,152 1000,190 0,190" /><Baseline points="0,188 1000,188" /><TextEquiv index="0"><Unicode>Wirt.</Unicode></TextEquiv></TextLine><TextLine id="l6" custom="register:de"><Coords points="0,190 1000,190 1000,228 0,228" /><Baseline points="0,226 1000,226" /><TextEquiv index="0"><Unicode>My word in Eckhart's sentence, Eckhart's sentence in the</Unicode></TextEquiv></TextLine><TextLine id="l7" custom="register:de"><Coords points="0,228 1000,228 1000,266 0,266" /><Baseline points="0,264 1000,264" /><TextEquiv index="0"><Unicode>press's type, the press's type on the page in my hand, the</Unicode></TextEquiv></TextLine><TextLine id="l8" custom="register:de"><Coords points="0,266 1000,266 1000,304 0,304" /><Baseline points="0,302 1000,302" /><TextEquiv index="0"><Unicode>page in my hand that had been copied from a manuscript</Unicode></TextEquiv></TextLine><TextLine id="l9" custom="register:de"><Coords points="0,304 1000,304 1000,342 0,342" /><Baseline points="0,340 1000,340" /><TextEquiv index="0"><Unicode>copied from my copy of a damaged original, the chain of</Unicode></TextEquiv></TextLine><TextLine id="l10" custom="register:de"><Coords points="0,342 1000,342 1000,380 0,380" /><Baseline points="0,378 1000,378" /><TextEquiv index="0"><Unicode>transmission running back through twenty-two years of my</Unicode></TextEquiv></TextLine><TextLine id="l11" custom="register:de"><Coords points="0,380 1000,380 1000,418 0,418" /><Baseline points="0,416 1000,416" /><TextEquiv index="0"><Unicode>private guilt to a winter morning in 1435 when a young man</Unicode></TextEquiv></TextLine><TextLine id="l12" custom="register:de"><Coords points="0,418 1000,418 1000,456 0,456" /><Baseline points="0,454 1000,454" /><TextEquiv index="0"><Unicode>sat alone with a cracked vellum and a question and answered</Unicode></TextEquiv></TextLine><TextLine id="l13" custom="register:de"><Coords points="0,456 1000,456 1000,494 0,494" /><Baseline points="0,492 1000,492" /><TextEquiv index="0"><Unicode>it, rightly or wrongly, with the full force of what he</Unicode></TextEquiv></TextLine><TextLine id="l14" custom="register:de"><Coords points="0,494 1000,494 1000,532 0,532" /><Baseline points="0,530 1000,530" /><TextEquiv index="0"><Unicode>understood.</Unicode></TextEquiv></TextLine><TextLine id="l15" custom="register:de"><Coords points="0,532 1000,532 1000,570 0,570" /><Baseline points="0,568 1000,568" /><TextEquiv index="0"><Unicode>I held the page.</Unicode></TextEquiv></TextLine><TextLine id="l16" custom="register:de"><Coords points="0,570 1000,570 1000,608 0,608" /><Baseline points="0,606 1000,606" /><TextEquiv index="0"><Unicode>Then I handed it back to Hans, who added it to the stack</Unicode></TextEquiv></TextLine><TextLine id="l17" custom="register:de"><Coords points="0,608 1000,608 1000,646 0,646" /><Baseline points="0,644 1000,644" /><TextEquiv index="0"><Unicode>without looking up.</Unicode></TextEquiv></TextLine><TextLine id="l18" custom="register:de"><Coords points="0,646 1000,646 1000,684 0,684" /><Baseline points="0,682 1000,682" /><TextEquiv index="0"><Unicode>I walked home through the cold.</Unicode></TextEquiv></TextLine><TextLine id="l19" custom="register:de"><Coords points="0,684 1000,684 1000,722 0,722" /><Baseline points="0,720 1000,720" /><TextEquiv index="0"><Unicode>I came here.</Unicode></TextEquiv></TextLine><TextLine id="l20" custom="register:de"><Coords points="0,722 1000,722 1000,760 0,760" /><Baseline points="0,758 1000,758" /><TextEquiv index="0"><Unicode>I picked up the pen.</Unicode></TextEquiv></TextLine><TextLine id="l21" custom="register:verbatim_la"><Coords points="0,760 1000,760 1000,798 0,798" /><Baseline points="0,796 1000,796" /><TextEquiv index="0"><Unicode>As the deer longs for the water-brooks.</Unicode></TextEquiv></TextLine><TextLine id="l22" custom="register:de"><Coords points="0,798 1000,798 1000,836 0,836" /><Baseline points="0,834 1000,834" /><TextEquiv index="0"><Unicode>So.</Unicode></TextEquiv></TextLine><TextLine id="l23" custom="register:la"><Coords points="0,836 1000,836 1000,874 0,874" /><Baseline points="0,872 1000,872" /><TextEquiv index="0"><Unicode>Finis.</Unicode></TextEquiv></TextLine><TextLine id="l24" custom="register:mixed"><Coords points="0,874 1000,874 1000,912 0,912" /><Baseline points="0,910 1000,910" /><TextEquiv index="0"><Unicode>Written in Erfurt, in the forty-third year of my life, in</Unicode></TextEquiv></TextLine><TextLine id="l25" custom="register:mixed"><Coords points="0,912 1000,912 1000,950 0,950" /><Baseline points="0,948 1000,948" /><TextEquiv index="0"><Unicode>the year of Our Lord 1457, without permission, without</Unicode></TextEquiv></TextLine><TextLine id="l26" custom="register:mixed"><Coords points="0,950 1000,950 1000,988 0,988" /><Baseline points="0,986 1000,986" /><TextEquiv index="0"><Unicode>excuse, and without, in the end, burning.</Unicode></TextEquiv></TextLine></TextRegion></Page></PcGts>