        {
          "type": "confidence",
          "detail": {
            "score": 0.97
          }
        }
      ]
    },
    {
      "number": 11,
      "text": "I have spent my life leaving myself in the pages.",
      "register": "de",
      "annotations": [
        {
          "type": "confidence",
          "detail": {
            "score": 0.97
          }
        }
      ]
    },
    {
      "number": 12,
      "text": "Not obviously. Not with vanity. I mean something",
