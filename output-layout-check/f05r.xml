<PcGts xmlns="http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15 http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15/pagecontent.xsd"><Metadata><Creator>xl-export</Creator><Created>2026-03-19T00:00:00Z</Created><LastChange>2026-03-19T00:00:00Z</LastChange></Metadata><Page imageFilename="" imageWidth="1000" imageHeight="1000"><TextRegion id="r1" custom="type:paragraph"><Coords points="0,0 1000,0 1000,1000 0,1000" /><TextLine id="l1" custom="register:de"><Coords points="0,0 1000,0 1000,55 0,55" /><Baseline points="0,53 1000,53" /><TextEquiv index="0"><Unicode>to the garden and he told me that Fust's man had</Unicode></TextEquiv></TextLine><TextLine id="l2" custom="register:de"><Coords points="0,55 1000,55 1000,110 0,110" /><Baseline points="0,108 1000,108" /><TextEquiv index="0"><Unicode>come through Erfurt and that he had spoken with him</Unicode></TextEquiv></TextLine><TextLine id="l3" custom="register:de"><Coords points="0,110 1000,110 1000,165 0,165" /><Baseline points="0,163 1000,163" /><TextEquiv index="0"><Unicode>for two hours and that he had been offered a</Unicode></TextEquiv></TextLine><TextLine id="l4" custom="register:de"><Coords points="0,165 1000,165 1000,220 0,220" /><Baseline points="0,218 1000,218" /><TextEquiv index="0"><Unicode>position in the Frankfurt workshop and that he had</Unicode></TextEquiv></TextLine><TextLine id="l5" custom="register:de"><Coords points="0,220 1000,220 1000,275 0,275" /><Baseline points="0,273 1000,273" /><TextEquiv index="0"><Unicode>decided to accept it.</Unicode></TextEquiv></TextLine><TextLine id="l6" custom="register:de"><Coords points="0,275 1000,275 1000,330 0,330" /><Baseline points="0,328 1000,328" /><TextEquiv index="0"><Unicode>He said: I have decided. Not I am thinking of or I</Unicode></TextEquiv></TextLine><TextLine id="l7" custom="register:de"><Coords points="0,330 1000,330 1000,385 0,385" /><Baseline points="0,383 1000,383" /><TextEquiv index="0"><Unicode>wonder if you would counsel me. He had decided. He</Unicode></TextEquiv></TextLine><TextLine id="l8" custom="register:de"><Coords points="0,385 1000,385 1000,440 0,440" /><Baseline points="0,438 1000,438" /><TextEquiv index="0"><Unicode>was telling me, not asking me. He was twenty years</Unicode></TextEquiv></TextLine><TextLine id="l9" custom="register:de"><Coords points="0,440 1000,440 1000,495 0,495" /><Baseline points="0,493 1000,493" /><TextEquiv index="0"><Unicode>old and he had decided and he was correct to have</Unicode></TextEquiv></TextLine><TextLine id="l10" custom="register:de"><Coords points="0,495 1000,495 1000,550 0,550" /><Baseline points="0,548 1000,548" /><TextEquiv index="0"><Unicode>decided and I knew it while he was speaking and the</Unicode></TextEquiv></TextLine><TextLine id="l11" custom="register:de"><Coords points="0,550 1000,550 1000,605 0,605" /><Baseline points="0,603 1000,603" /><TextEquiv index="0"><Unicode>knowing and the losing arrived at the same moment,</Unicode></TextEquiv></TextLine><TextLine id="l12" custom="register:de"><Coords points="0,605 1000,605 1000,660 0,660" /><Baseline points="0,658 1000,658" /><TextEquiv index="0"><Unicode>which I was not prepared for, which I am still not</Unicode></TextEquiv></TextLine><TextLine id="l13" custom="register:de"><Coords points="0,660 1000,660 1000,715 0,715" /><Baseline points="0,713 1000,713" /><TextEquiv index="0"><Unicode>prepared for, which is why this folio looks the way</Unicode></TextEquiv></TextLine><TextLine id="l14" custom="register:de"><Coords points="0,715 1000,715 1000,770 0,770" /><Baseline points="0,768 1000,768" /><TextEquiv index="0"><Unicode>it does.</Unicode></TextEquiv></TextLine><TextLine id="l15" custom="register:de"><Coords points="0,770 1000,770 1000,825 0,825" /><Baseline points="0,823 1000,823" /><TextEquiv index="0"><Unicode>I said [—]. He said [—]. I said that I was [—] proud</Unicode></TextEquiv></TextLine><TextLine id="l16" custom="register:de"><Coords points="0,825 1000,825 1000,880 0,880" /><Baseline points="0,878 1000,878" /><TextEquiv index="0"><Unicode>[—].</Unicode></TextEquiv></TextLine><TextLine id="l17" custom="register:de"><Coords points="0,880 1000,880 1000,935 0,935" /><Baseline points="0,933 1000,933" /><TextEquiv index="0"><Unicode>He asked me then for my blessing.</Unicode></TextEquiv></TextLine><TextLine id="l18" custom="register:de"><Coords points="0,935 1000,935 1000,990 0,990" /><Baseline points="0,988 1000,988" /><TextEquiv index="0"><Unicode>This part is not damaged. I want you to notice that.</Unicode></TextEquiv></TextLine></TextRegion></Page></PcGts>