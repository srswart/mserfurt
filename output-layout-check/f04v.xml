<PcGts xmlns="http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15 http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15/pagecontent.xsd"><Metadata><Creator>xl-export</Creator><Created>2026-03-19T00:00:00Z</Created><LastChange>2026-03-19T00:00:00Z</LastChange></Metadata><Page imageFilename="" imageWidth="1000" imageHeight="1000"><TextRegion id="r1" custom="type:paragraph"><Coords points="0,0 1000,0 1000,1000 0,1000" /><TextLine id="l1" custom="register:de"><Coords points="0,0 1000,0 1000,76 0,76" /><Baseline points="0,74 1000,74" /><TextEquiv index="0"><Unicode>tear down. With the same precise, almost courtly</Unicode></TextEquiv></TextLine><TextLine id="l2" custom="register:de"><Coords points="0,76 1000,76 1000,152 0,152" /><Baseline points="0,150 1000,150" /><TextEquiv index="0"><Unicode>curiosity he brought to everything. He asked as a</Unicode></TextEquiv></TextLine><TextLine id="l3" custom="register:de"><Coords points="0,152 1000,152 1000,228 0,228" /><Baseline points="0,226 1000,226" /><TextEquiv index="0"><Unicode>craftsman, which is what he was, and I answered him</Unicode></TextEquiv></TextLine><TextLine id="l4" custom="register:de"><Coords points="0,228 1000,228 1000,304 0,304" /><Baseline points="0,302 1000,302" /><TextEquiv index="0"><Unicode>as a craftsman, which is what I am, and for several</Unicode></TextEquiv></TextLine><TextLine id="l5" custom="register:de"><Coords points="0,304 1000,304 1000,380 0,380" /><Baseline points="0,378 1000,378" /><TextEquiv index="0"><Unicode>weeks we had conversations about the technical</Unicode></TextEquiv></TextLine><TextLine id="l6" custom="register:de"><Coords points="0,380 1000,380 1000,456 0,456" /><Baseline points="0,454 1000,454" /><TextEquiv index="0"><Unicode>properties of the press that I found, God forgive</Unicode></TextEquiv></TextLine><TextLine id="l7" custom="register:de"><Coords points="0,456 1000,456 1000,532 0,532" /><Baseline points="0,530 1000,530" /><TextEquiv index="0"><Unicode>me, genuinely interesting.</Unicode></TextEquiv></TextLine><TextLine id="l8" custom="register:de"><Coords points="0,532 1000,532 1000,608 0,608" /><Baseline points="0,606 1000,606" /><TextEquiv index="0"><Unicode>I should have seen it then. Perhaps I did see it and</Unicode></TextEquiv></TextLine><TextLine id="l9" custom="register:de"><Coords points="0,608 1000,608 1000,684 0,684" /><Baseline points="0,682 1000,682" /><TextEquiv index="0"><Unicode>decided not to know.</Unicode></TextEquiv></TextLine><TextLine id="l10" custom="register:de"><Coords points="0,684 1000,684 1000,760 0,760" /><Baseline points="0,758 1000,758" /><TextEquiv index="0"><Unicode>He told me on a Thursday. I remember [—] the light.</Unicode></TextEquiv></TextLine><TextLine id="l11" custom="register:de"><Coords points="0,760 1000,760 1000,836 0,836" /><Baseline points="0,834 1000,834" /><TextEquiv index="0"><Unicode>There is a particular light in the scriptorium in</Unicode></TextEquiv></TextLine><TextLine id="l12" custom="register:de"><Coords points="0,836 1000,836 1000,912 0,912" /><Baseline points="0,910 1000,910" /><TextEquiv index="0"><Unicode>late [—] that I have always [—]. He asked if we</Unicode></TextEquiv></TextLine><TextLine id="l13" custom="register:de"><Coords points="0,912 1000,912 1000,988 0,988" /><Baseline points="0,986 1000,986" /><TextEquiv index="0"><Unicode>could speak privately and I said yes and we walked</Unicode></TextEquiv></TextLine></TextRegion></Page></PcGts>