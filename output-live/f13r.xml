<?xml version='1.0' encoding='utf-8'?>
<PcGts xmlns="http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15 http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15/pagecontent.xsd"><Metadata><Creator>xl-export</Creator><Created>2026-03-19T00:00:00Z</Created><LastChange>2026-03-19T00:00:00Z</LastChange></Metadata><Page imageFilename="" imageWidth="1000" imageHeight="1000"><TextRegion id="r1" custom="type:paragraph"><Coords points="0,0 1000,0 1000,1000 0,1000" /><TextLine id="l1" custom="register:mixed"><Coords points="0,0 1000,0 1000,43 0,43" /><Baseline points="0,41 1000,41" /><TextEquiv index="0"><Unicode>mir meine Sünden. Mache mich demütig und gehorsam.</Unicode></TextEquiv></TextLine><TextLine id="l2" custom="register:mixed"><Coords points="0,43 1000,43 1000,86 0,86" /><Baseline points="0,84 1000,84" /><TextEquiv index="0"><Unicode>Stärke meinen Willen, daß ich die Regel halte und</Unicode></TextEquiv></TextLine><TextLine id="l3" custom="register:mixed"><Coords points="0,86 1000,86 1000,129 0,129" /><Baseline points="0,127 1000,127" /><TextEquiv index="0"><Unicode>dir treu diene bis an mein Ende. Das dritte Buch.</Unicode></TextEquiv></TextLine><TextLine id="l4" custom="register:mixed"><Coords points="0,129 1000,129 1000,172 0,172" /><Baseline points="0,170 1000,170" /><TextEquiv index="0"><Unicode>Ich kante die Stelle ane das Lesen: Ich habe sie</Unicode></TextEquiv></TextLine><TextLine id="l5" custom="register:mixed"><Coords points="0,172 1000,172 1000,215 0,215" /><Baseline points="0,213 1000,213" /><TextEquiv index="0"><Unicode>zweimal mit meiner eigenen Hand geschrieben, ich</Unicode></TextEquiv></TextLine><TextLine id="l6" custom="register:mixed"><Coords points="0,215 1000,215 1000,258 0,258" /><Baseline points="0,256 1000,256" /><TextEquiv index="0"><Unicode>weiß, wo die Zeilen auf der Seite brechen, ich weiß</Unicode></TextEquiv></TextLine><TextLine id="l7" custom="register:mixed"><Coords points="0,258 1000,258 1000,301 0,301" /><Baseline points="0,299 1000,299" /><TextEquiv index="0"><Unicode>um die besondere Art des Lateins in diesem Stück,</Unicode></TextEquiv></TextLine><TextLine id="l8" custom="register:mixed"><Coords points="0,301 1000,301 1000,344 0,344" /><Baseline points="0,342 1000,342" /><TextEquiv index="0"><Unicode>die Weise, wie die Sätze greifen und greifen und</Unicode></TextEquiv></TextLine><TextLine id="l9" custom="register:mixed"><Coords points="0,344 1000,344 1000,387 0,387" /><Baseline points="0,385 1000,385" /><TextEquiv index="0"><Unicode>dann ankommen. Unum est ex pulcherrimis locis in</Unicode></TextEquiv></TextLine><TextLine id="l10" custom="register:mixed"><Coords points="0,387 1000,387 1000,430 0,430" /><Baseline points="0,428 1000,428" /><TextEquiv index="0"><Unicode>libro et unum ex periculosissimis, quia describit</Unicode></TextEquiv></TextLine><TextLine id="l11" custom="register:mixed"><Coords points="0,430 1000,430 1000,473 0,473" /><Baseline points="0,471 1000,471" /><TextEquiv index="0"><Unicode>tempus ante conversionem Augustini cum honestate</Unicode></TextEquiv></TextLine><TextLine id="l12" custom="register:mixed"><Coords points="0,473 1000,473 1000,516 0,516" /><Baseline points="0,514 1000,514" /><TextEquiv index="0"><Unicode>quae Ecclesiam inquietavit per mille annos et quae</Unicode></TextEquiv></TextLine><TextLine id="l13" custom="register:mixed"><Coords points="0,516 1000,516 1000,559 0,559" /><Baseline points="0,557 1000,557" /><TextEquiv index="0"><Unicode>probabiliter causa est cur Augustinus eam superavit:</Unicode></TextEquiv></TextLine><TextLine id="l14" custom="register:mixed"><Coords points="0,559 1000,559 1000,602 0,602" /><Baseline points="0,600 1000,600" /><TextEquiv index="0"><Unicode>non potes confessionem supprimere si confessor iam</Unicode></TextEquiv></TextLine><TextLine id="l15" custom="register:mixed"><Coords points="0,602 1000,602 1000,645 0,645" /><Baseline points="0,643 1000,643" /><TextEquiv index="0"><Unicode>est theologus veneratissimus in Christianitate.</Unicode></TextEquiv></TextLine><TextLine id="l16" custom="register:de"><Coords points="0,645 1000,645 1000,688 0,688" /><Baseline points="0,686 1000,686" /><TextEquiv index="0"><Unicode>Ich neigete mich nahe heran.</Unicode></TextEquiv></TextLine><TextLine id="l17" custom="register:mixed"><Coords points="0,688 1000,688 1000,731 0,731" /><Baseline points="0,729 1000,729" /><TextEquiv index="0"><Unicode>Ich las die lateinischen Buchstaben in der gesetzten</Unicode></TextEquiv></TextLine><TextLine id="l18" custom="register:mixed"><Coords points="0,731 1000,731 1000,774 0,774" /><Baseline points="0,772 1000,772" /><TextEquiv index="0"><Unicode>Schrift, Buchstabe für Buchstabe rückwerts, wie man</Unicode></TextEquiv></TextLine><TextLine id="l19" custom="register:mixed"><Coords points="0,774 1000,774 1000,817 0,817" /><Baseline points="0,815 1000,815" /><TextEquiv index="0"><Unicode>es lernen muß, und ich — *Sed cum animam meam ad</Unicode></TextEquiv></TextLine><TextLine id="l20" custom="register:mixed"><Coords points="0,817 1000,817 1000,860 0,860" /><Baseline points="0,858 1000,858" /><TextEquiv index="0"><Unicode>illud studium convertissem, quomodo verba sancta in</Unicode></TextEquiv></TextLine><TextLine id="l21" custom="register:mixed"><Coords points="0,860 1000,860 1000,903 0,903" /><Baseline points="0,901 1000,901" /><TextEquiv index="0"><Unicode>ordine inverso posita intelligere poteram, cum ratio</Unicode></TextEquiv></TextLine><TextLine id="l22" custom="register:mixed"><Coords points="0,903 1000,903 1000,946 0,946" /><Baseline points="0,944 1000,944" /><TextEquiv index="0"><Unicode>humana in tenebris laboraret —* ich empfand ein</Unicode></TextEquiv></TextLine><TextLine id="l23" custom="register:mixed"><Coords points="0,946 1000,946 1000,989 0,989" /><Baseline points="0,987 1000,987" /><TextEquiv index="0"><Unicode>seltsam Brennen in der Brust, als wären die Worte</Unicode></TextEquiv></TextLine></TextRegion></Page></PcGts>