  "vellum_stock": "standard",
  "lines": [
    {
      "number": 1,
      "text": "ist das geheimnis: man lernt das schreiben nit aus büchern.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 2,
      "text": "Man lernt es aus dem stoff selbst. Man sitzt nieder vnd",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 3,
      "text": "man nimmt die feder vnd man fängt an, vnd das anfangen",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 4,
      "text": "lehret einen das erste. Das zweite lernt man durch das",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 5,
      "text": "fortfahren vnd das dritte durch das nit-aufhören. Das",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 6,
      "text": "nit-aufhören ist das schwierigste von allen dreien. Ich",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 7,
      "text": "hab es dreißig mal gewollt, aufzuhören. Dreißig male in",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 8,
      "text": "dreißig jaren, mindestens einmal je jar. Ich hab es nit.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 9,
      "text": "Von dem verhältnis zwischen dem schreiber vnd dem auctor —",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 10,
      "text": "das iß ein frage, die mich immer beschäftiget hat. Der",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 11,
      "text": "auctor hat geschrieben. Der schreiber schreibt nach. Aber",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 12,
      "text": "was ist das — nachschreiben? Ist es ein dienen? Ein ehren?",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 13,
      "text": "Oder ist es ein eigenes werk, das von dem anderen werk",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 14,
      "text": "lebet, aber nit dasselbe ist? Ich kenne keine antwort.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 15,
      "text": "Aber ich habe beobachtet: wenn ich denselben text zweimal",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 16,
      "text": "abschreibe, ist er nit dasselbe buch. Der erste abschrift",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 17,
      "text": "ist von meiner jugend. Der zweite ist von meinem alter.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 18,
      "text": "Sie sehen gleich aus. Sie sind nit gleich. Der auctor hat",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 19,
      "text": "dasselbe geschrieben. Der schreiber hat sich verändert.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 20,
      "text": "Vnd die veränderung des schreibers — ist die im buch?",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 21,
      "text": "Ich glaube, sie ist darin. Ein wenig. In der dicke eines",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 22,
      "text": "striches, in der neigung eines buchstabens. Die hand",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    }
  ]
}
