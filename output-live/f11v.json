{
  "id": "f11v",
  "recto_verso": "verso",
  "gathering_position": 11,
  "damage": null,
  "hand_notes": null,
  "section_breaks": [10],
  "vellum_stock": "standard",
  "lines": [
    {
      "number": 1,
      "text": "wunder, alle visionen, alle erleuchtungen. Gib mir das",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 2,
      "text": "gewöhnliche. Gib mir die feder vnd das pergament vnd den",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 3,
      "text": "morgen vnd das tun. Das ist genug für mich.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 4,
      "text": "Augustinus hat geschrieben: fecisti nos ad te. Du hast",
      "register": "mixed",
      "annotations": [{"type": "confidence", "detail": {"score": 0.95}}]
    },
    {
      "number": 5,
      "text": "uns gemacht auf dich hin. Nicht für uns selbst. Auf dich",
      "register": "mixed",
      "annotations": [{"type": "confidence", "detail": {"score": 0.95}}]
    },
    {
      "number": 6,
      "text": "hin. Das heißt: es gibt eine richtung. Das hertz ist nit",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 7,
      "text": "ein ding das in sich selbst ruhet — es ist ein ding das",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 8,
      "text": "gerichtet ist, vnd ehe es an seinem ziel ist, ist es",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 9,
      "text": "unruhig. Das ist die unruhe des schreibers. Die gute unruhe.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 10,
      "text": "Ich hab dieses wort abgeschrieben — fecisti nos ad te —",
      "register": "mixed",
      "annotations": [{"type": "confidence", "detail": {"score": 0.95}}]
    },
    {
      "number": 11,
      "text": "in dem großen winter vor sieben jaren, vnd es hat mich",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 12,
      "text": "damals nit berührt. Ich schrib es als eines von vielen",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 13,
      "text": "worten, vnd es gieng weiter. Nun — in diesem jar — lese",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 14,
      "text": "ich das buch, das ich schrieb, vnd da stehen jene wort,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 15,
      "text": "vnd ich stehe davor vnd weiß nit, ob ich sie damals kannte",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 16,
      "text": "oder ob sie mich erst jetzt kennen. So ist das mit dem",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 17,
      "text": "heiligen wort — es wartet auf den leser, bis der leser",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 18,
      "text": "bereit ist. Vnd das warten des wortes ist seine gnade.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 19,
      "text": "Nun bin ich bereit, glaube ich. Vnd das wort ist noch da.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 20,
      "text": "Es hat auf mich gewartet, sieben jahre lang, in dem buch,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 21,
      "text": "das ich schrieb, das meine hand schrieb, die unsichere",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 22,
      "text": "hand. Vnd die hand, die das wort schrieb, ist dieselbe",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    }
  ]
}
