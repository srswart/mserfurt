{
  "id": "f03v",
  "recto_verso": "verso",
  "gathering_position": 3,
  "damage": null,
  "hand_notes": null,
  "section_breaks": [],
  "vellum_stock": "standard",
  "lines": [
    {
      "number": 1,
      "text": "Das ist die ironie, die ich nit sehen wollt in den ersten",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 2,
      "text": "jaren, vnd die ich jetzt sehe: Augustinus hat sein bekenntnis",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 3,
      "text": "geschrieben, vnd ich hab es abgeschrieben, vnd das abschreiben",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 4,
      "text": "war selbst ein art bekenntnis, vnd ich hab es nit gemerkt.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 5,
      "text": "Oder vielleicht hab ichs gemerkt vnd hab mich gewehret",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 6,
      "text": "dagegen. Das ist auch möglich. Der mensch is gutt im",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 7,
      "text": "sich-wehren, auch wan er nit weiß, wogegen er sich wehret.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 8,
      "text": "Ich hab mir oft gedacht: ein schreiber, der ein bekenntnis",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 9,
      "text": "abschreibt, ist er dazu gehalten, selbst zu bekennen?",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 10,
      "text": "Oder ist er nur gehalten, sauberlich zu schreiben vnd",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 11,
      "text": "kein tinte zu verschütten? Ich fürchte, die antwort ist",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 12,
      "text": "die erste, vnd die erste ist die schwärere. Darumb schreib",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 13,
      "text": "ich jetzt, nach sieben jaren, mein eigenes bekenntnis,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 14,
      "text": "obwol ich nit Augustinus bin vnd kein werk habe, das",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 15,
      "text": "der rede wert wäre. Mein werk ist das abschreiben anderer",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 16,
      "text": "werke. Aber das abschreiben ist selbst ein werk, vnd ich",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 17,
      "text": "will versuchen zu sagen, was es mir gewesen ist. Nit für",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 18,
      "text": "jemand anders — dafür bin ich zu gering — sunder für mich",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 19,
      "text": "selbst, vnd vielleicht für Gott, der ja weiß, ob es wahr ist",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 20,
      "text": "oder nit, vnd der mich nit braucht, daz ich es ihm erzähle,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 21,
      "text": "aber dem es vielleicht gefällt, wenn ich es versuche zu",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 22,
      "text": "sagen. Wie Augustinus es versuchte. Das kann ich ihm doch",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    }
  ]
}
