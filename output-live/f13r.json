{
  "id": "f13r",
  "recto_verso": "recto",
  "gathering_position": 13,
  "damage": null,
  "hand_notes": null,
  "section_breaks": [],
  "vellum_stock": "standard",
  "lines": [
    {
      "number": 1,
      "text": "vnd das wehtun ist gut. Das hab ich jetzt gesagt vnd ich",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 2,
      "text": "stehe dazu. Das ehrliche denken iß der anfang des ehrlichen",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 3,
      "text": "schreibens vnd der anfang des ehrlichen betens, vnd ich",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 4,
      "text": "habe es zu spät gelernt vnd lerne es noch. Aber ich lerne.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 5,
      "text": "Das hab ich in diesem buch versucht: ehrlich zu sein.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 6,
      "text": "Ich weiß nit, ob es mir gelungen ist. Ehrlichkeit iß",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 7,
      "text": "schwerer als schreiben, vnd schreiben ist schon schwer.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 8,
      "text": "Man meint, man ist ehrlich, vnd dann merkt man: nein,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 9,
      "text": "da ist noch eine schicht darunter, vnd darunter noch eine.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 10,
      "text": "Wie das pergament, das man geschabt hat — man schabet vnd",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 11,
      "text": "denkt, man iß fertig, vnd dann sieht man, daß noch etwas",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 12,
      "text": "bleibt. Gott muß das letzte schaben. Ich kann es nit.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 13,
      "text": "Das ist vielleicht das wichtigste, was ich weiß: ich kann",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 14,
      "text": "mich nit selbst vollständig reinigen. Das ist Gottes werk.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 15,
      "text": "Ich kann nur das, was meins ist: die feder nehmen, das",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 16,
      "text": "blatt bereiten, die tinte anrühren vnd anfangen. Das",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 17,
      "text": "kann ich tun. Das tu ich. Das werde ich tun, solang",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 18,
      "text": "ich eine hand habe vnd ein auge vnd einen morgen.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 19,
      "text": "Vnd dann — wenn die hand nit mehr will vnd das auge nit",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 20,
      "text": "mehr sieht vnd der morgen nit mehr kommt — dann ist der",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 21,
      "text": "schreiber fertig, vnd das wort, das durch ihn gieng, gehet",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 22,
      "text": "weiter durch andere hände, andere augen, andere morgen.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    }
  ]
}
