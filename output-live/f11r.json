{
  "id": "f11r",
  "recto_verso": "recto",
  "gathering_position": 11,
  "damage": null,
  "hand_notes": null,
  "section_breaks": [],
  "vellum_stock": "standard",
  "lines": [
    {
      "number": 1,
      "text": "Es ist ein seltsames ding, daß man etwas lernt durch das",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 2,
      "text": "tun vnd nit durch das denken. Aber so ist es. Man schreibt",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 3,
      "text": "das wort vnd das wort geht ein. Es braucht keine erklärung.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 4,
      "text": "Erklärungen kommen danach, wenn man glück hat. Oder gar",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 5,
      "text": "nit — vnd auch das iß möglich. Man muß nit alles verstehen,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 6,
      "text": "was man tut. Man muß es nur tun. Daz hat mir der meister",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 7,
      "text": "gesagt, vnd Augustinus hat es gesagt, vnd jetzt sage ich",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 8,
      "text": "es auch, aber als einer, der es erst jetzt glaubt.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 9,
      "text": "Die Buße als tägliche übung — das ist das, wozu ich",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 10,
      "text": "gekommen bin. Nit als große geste einmal, sunder als",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 11,
      "text": "kleines tun täglich. Wie das schreiben. Jeden morgen",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 12,
      "text": "nimmt man die feder. Man fragt nit, ob man heute lust hat.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 13,
      "text": "Man nimmt die feder vnd schreibt. So auch mit der Buße:",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 14,
      "text": "jeden morgen wendet man sich um, auch wenn es nit nach",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 15,
      "text": "umkehren zumute ist. Die lust kommt vielleicht danach.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 16,
      "text": "Oder sie kommt nit. Das ist nit der maßstab. Das tun iß",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 17,
      "text": "der maßstab. Das hat mir das schreiben gelehrt. Das hätte",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 18,
      "text": "mir kein lehrer lehren können — es mußte durch die hand",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 19,
      "text": "kommen, durch das täglich-morgens-die-feder-nehmen.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 20,
      "text": "Gott hat mir das gelehrt durch das amt. Das ist seine",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 21,
      "text": "gnade — daß er durch das kleine das große lehret, durch",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 22,
      "text": "das gewöhnliche das heilige. Das ist mir lieber als alle",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    }
  ]
}
