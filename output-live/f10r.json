{
  "id": "f10r",
  "recto_verso": "recto",
  "gathering_position": 10,
  "damage": null,
  "hand_notes": null,
  "section_breaks": [1],
  "vellum_stock": "standard",
  "lines": [
    {
      "number": 1,
      "text": "Nun bin ich dreißig jar alt in dem schreiben vnd die hand",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 2,
      "text": "ist noch unsicher. Das hat mich in den ersten jahren sehr",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 3,
      "text": "geschmerzt, wann ich dachte: nach dreißig jaren soll man",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 4,
      "text": "sicher sein. Ein zimmermann nach dreißig jaren ist sicher.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 5,
      "text": "Ein schmied nach dreißig jaren ist sicher. Warum nit ich?",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 6,
      "text": "Das hab ich meinem meister einmal gesagt, vnd er lachte",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 7,
      "text": "nit vnd sagte: Konrad, der zimmermann macht den stuhl.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 8,
      "text": "Der stuhl ist fertig vnd der zimmermann ist fertig. Du",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 9,
      "text": "aber machest das wort Gottes nach. Das ist niemals fertig.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 10,
      "text": "Vnd also kann auch der schreiber niemals fertig sein.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 11,
      "text": "Damals habe ich gedacht, das ist ein schönes wort vnd",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 12,
      "text": "stimmt es vielleicht nit. Nun — in meinem dreyundviertzigsten",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 13,
      "text": "jar — glaube ich, es stimmt. Die hand bleibt unsicher,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 14,
      "text": "weil das, was sie schreibt, größer ist als die hand.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 15,
      "text": "Vnd das zittern ist nit ein fehler — das zittern ist die",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 16,
      "text": "richtige antwort auf das, was man in den händen trägt.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 17,
      "text": "Das hat mich getröstet vnd ich halte daran fest, obwohl",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 18,
      "text": "mir manchmal die stimme sagt: es ist nur ein vorwand,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 19,
      "text": "Konrad, ein gutt schreiber zittert nit. Vnd ich antworte",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 20,
      "text": "dieser stimme: ich kenne einen, der gut war, vnd er",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 21,
      "text": "zitterte auch. Vnd die stimme schweigt dann manchmal.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 22,
      "text": "Vnd manchmal nit. Aber das ist das leben, vnd ich nehme",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    }
  ]
}
