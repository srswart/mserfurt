  "lines": [
    {
      "number": 1,
      "text": "Es war abgegeben worden an den bruder, für den es gemacht",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 2,
      "text": "worden war. Bruder Dietrich, der älteste im haus, der",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 3,
      "text": "sehens arm geworden war vnd dem der abt einen schönen",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 4,
      "text": "psalter hatte schreiben laßen für die letzen jahre seines",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 5,
      "text": "lebens. Ich kunnte nit hin zu dem bruder gehen vnd sagen:",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 6,
      "text": "gib mir das buch zurück, ich hab ein fehler darin.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 7,
      "text": "Er war sehens arm. Er las darin täglich. Das buch war",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 8,
      "text": "für ihn das fenster, durch das er noch Gott sehen kunnte.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 9,
      "text": "Vnd in disem fenster fehlte ein e. Caeli narrant. Nit",
      "register": "mixed",
      "annotations": [{"type": "confidence", "detail": {"score": 0.95}}]
    },
    {
      "number": 10,
      "text": "enarrant. Ich hab darüber nachgedacht, ob ein einziges",
      "register": "mixed",
      "annotations": [{"type": "confidence", "detail": {"score": 0.95}}]
    },
    {
      "number": 11,
      "text": "e das gebet eines alten mannes beschädigen kan. Ich weiß",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 12,
      "text": "die antwort nit. Ich glaube: Gott kann den fehler lesen",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 13,
      "text": "vnd kann dahinter sehen, was der schreiber meinte. Gott",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 14,
      "text": "ist nit so eitel wie ein schreibmeister. Aber ich weiß",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 15,
      "text": "nit, ob ich das glaube, weil es wahr ist, oder weil ich",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 16,
      "text": "es glauben will, vnd das ist der unterschied, der mich",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 17,
      "text": "noch nach zwey jaren wachhet in der nacht. Der fehler iß",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 18,
      "text": "da. Das buch ist da. Das e fehlt. Es ist wie eine sünde,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 19,
      "text": "die man begangen hat in einem anderen menschen — man kan",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 20,
      "text": "sie bereuen, aber man kan sie nit wegkratzen wie tinten",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 21,
      "text": "auf pergament. Sie bleibet eingeschrieben in dem leben",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 22,
      "text": "des anderen, vnd man trägt das mit sich, weil man muß.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    }
  ]
}
