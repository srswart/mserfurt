{
  "id": "f07r",
  "recto_verso": "recto",
  "gathering_position": 7,
  "damage": null,
  "hand_notes": null,
  "section_breaks": [8],
  "vellum_stock": "standard",
  "lines": [
    {
      "number": 1,
      "text": "manchmal der weg dahin. Das habe ich mir gesagt, vnd ich",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 2,
      "text": "weiß nit, ob es stimmt, aber ich halte daran fest.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 3,
      "text": "Es ist jetzt der winter des jares MCCCCLVII. Der frost",
      "register": "mixed",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 4,
      "text": "hat Erffordt früh gefaßt — schon im oktober lagen die",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 5,
      "text": "straßen weiß. Die Gera ist halb gefroren. Man hört sie",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 6,
      "text": "nit mehr rauschen von meinem fenster aus — sie geht still",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 7,
      "text": "unter dem eis, heimlich, wie ein gedanke, den man nit",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 8,
      "text": "ausspricht. Der dom stehet in dem nebel. Die mauren der",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 9,
      "text": "stat sind so grau wie das pergament, das lange gelegen hat.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 10,
      "text": "Die leute auf dem markt reden schnell vnd gehen schnell,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 11,
      "text": "wann die kälte duldet kein langes stehen. Aber ich stehe",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 12,
      "text": "manchmal am fenster vnd sehe hinaus vnd ich denke: das",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 13,
      "text": "ist Erffordt, vnd ich bin darin wie ein buchstabe in einem",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 14,
      "text": "wort, vnd das wort bin ich nit, ich bin nur ein teil davon,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 15,
      "text": "vnd der sinn liegt in dem ganzen vnd nit in dem teil.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 16,
      "text": "Das mag mir der schreiber vertrauen: kein buchstabe weiß",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 17,
      "text": "das wort, in dem er stehet. Kein wort weiß den satz.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 18,
      "text": "Kein satz weiß das buch. Vnd kein buch weiß — aber hier",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 19,
      "text": "muß ich aufhören, wann das, was über dem buch ist, das",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 20,
      "text": "mag ich nit in worte faßen. Das gehört nit mir. Ich bin",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 21,
      "text": "nur ein schreiber, ein abschreiber, vnd dieser gedanke",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 22,
      "text": "ist mir zu groß, also laß ich ihn stehen vnd gehe wieder",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    }
  ]
}
