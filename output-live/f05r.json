  "section_breaks": [10],
  "vellum_stock": "standard",
  "lines": [
    {
      "number": 1,
      "text": "Ich hab über das pergament nachgedacht, vnd das ist nit",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 2,
      "text": "so gering, wie es klingt. Das pergament ist nit gleich.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 3,
      "text": "Jedes stück hat seinen eigenen willen, seine eigene haut.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 4,
      "text": "Manche haut nimmt die tinte an wie ein durstiger mensch",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 5,
      "text": "wasser nimmt. Manche haut sperret sich vnd die tinte",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 6,
      "text": "stehet oben drauf wie öl auf dem wasser vnd will nit",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 7,
      "text": "einsinken. Dann muß man sehr langsam fahren mit der feder,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 8,
      "text": "sehr leise, vnd man muß warten auf die haut, bis sie",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 9,
      "text": "einverstanden ist. Das ist eine art gebet, das ich nit",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 10,
      "text": "zu nennen wüßte, wenn man mich fragt. Ich tue es nit.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 11,
      "text": "Es gibt hauten, die aus jungen tieren kommen, vnd man",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 12,
      "text": "spüret das beim schreiben. Sie sind weich vnd nachgiebig",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 13,
      "text": "vnd dankbar für die tinte. Vnd es gibt alte hauten, die",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 14,
      "text": "lange gedehnet worden sind, vnd sie haben etwas hartes",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 15,
      "text": "darin, etwas das nit nachgeben will, vnd man reibet die",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 16,
      "text": "feder daran wie an einem stein, vnd der stein merket es",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 17,
      "text": "kaum. Ich habe gelernt, die haut zu fühlen bevor ich",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 18,
      "text": "schreibe — ich lege die hand flach darauf vnd ich warte,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 19,
      "text": "vnd manchmal — das klingt närrisch, vnd ist es vielleicht —",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 20,
      "text": "manchmal antwortet die haut. Sie wird warm oder kalt.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 21,
      "text": "Sie sagt mir, was sie tragen kann. Die fehler kommen oft",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 22,
      "text": "nit von mir, sunder davon, daß ich auf die haut nit acht",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    }
  ]
}
