{
  "id": "f02v",
  "recto_verso": "verso",
  "gathering_position": 2,
  "damage": null,
  "hand_notes": null,
  "section_breaks": [9],
  "vellum_stock": "standard",
  "lines": [
    {
      "number": 1,
      "text": "Von dem Psalter wil ich reden, wann er ist mir das schwärste",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 2,
      "text": "gewesen von allen büchern, die ich hab abgeschrieben.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 3,
      "text": "Nit von der schwerheit der wort — die psalmen hat man",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 4,
      "text": "mir als kind in daz hertz gelegt, sie sitzen darin wie",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 5,
      "text": "steine in einem bett — sunder von der schwerheit der",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 6,
      "text": "verantwortung. Wan ich den Psalter schrib, do schrib ich",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 7,
      "text": "nit meine wort, ich schrib Gottes wort durch Davids mund,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 8,
      "text": "vnd jeder fehler darin iß nit mein fehler, er iß ein",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 9,
      "text": "wunde in dem heiligen fleisch. Das bedrücket mich.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 10,
      "text": "Ich hab den Psalter dreymal ganz abgeschrieben in dreißig",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 11,
      "text": "jaren. Das erste mal war ich jung, vnd die hand was",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 12,
      "text": "frisch vnd ich hatte keine angst. Das zweite mal wüßt",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 13,
      "text": "ich schon, was es heißet, das heilige wort in der hand",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 14,
      "text": "zu tragen vnd nit zu wißen, ob die hand würdig sei.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 15,
      "text": "Das dritte mal — vor zweyen jaren — habe ich gezittert",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 16,
      "text": "an dem ersten wort, dem Beatus vir. Selig der man —",
      "register": "mixed",
      "annotations": [{"type": "confidence", "detail": {"score": 0.95}}]
    },
    {
      "number": 17,
      "text": "was iß selikheit? Ich habe das nit gewüßt, do ich",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 18,
      "text": "es schrib, vnd ich weis es auch jetzt nit, aber das",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 19,
      "text": "schreiben selbst ist eine art von bitten, vnd das bitten",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 20,
      "text": "hat sein eigenes recht, auch wan man nit verstehet, was",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 21,
      "text": "man bittet. Das hab ich von dem Psalter gelernt, nit",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 22,
      "text": "vom lesen, sunder vom schreiben. Das ist der unterschied.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    }
  ]
}
