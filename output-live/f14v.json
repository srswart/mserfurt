{
  "id": "f14v",
  "recto_verso": "verso",
  "gathering_position": 14,
  "damage": null,
  "hand_notes": null,
  "section_breaks": [1, 8, 14],
  "vellum_stock": "irregular",
  "lines": [
    {
      "number": 1,
      "text": "Dritten october. Kalt. Der erste reif auf den ziegeln.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 2,
      "text": "Ich hab heute den Paulusbrief weiter kopiert, für den bruder,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 3,
      "text": "der es eilig hat. Ich mache keine fehler, wenn ich es",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 4,
      "text": "eilig mache. Das ist sonderbar. Die ruhe lädt fehler ein.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 5,
      "text": "Die eile lädt sie nit ein. Vielleicht weil die eile die",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 6,
      "text": "hand befreit vnd die ruhe den kopff einlädt, sich einzumischen.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 7,
      "text": "Wieder: was der meister sagte. Er hatte recht.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 8,
      "text": "Sechsten october. Der abt fragte mich heute, wie es mir",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 9,
      "text": "geht. Ich sagte: gut, Vater. Er sah mich lang an. Dann",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 10,
      "text": "sagte er: bete mehr. Ich sagte: ja. Er ging. Ich weiß,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 11,
      "text": "daß ich nit genug bete. Er weiß es auch. Wir haben beide",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 12,
      "text": "nit gesagt, was wir beide wußten. Das ist manchmal die",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 13,
      "text": "gütigste art zu reden: das schweigen.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 14,
      "text": "Neunten october. Ich habe heute in einem alten buch gelesen,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 15,
      "text": "das ein fremder schreiber gemacht hat, vor langer zeit.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 16,
      "text": "Seine hand ist ruhig vnd groß vnd sicher. Ich beneide ihn.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 17,
      "text": "Das ist sündhaft. Ich bereue es. Vnd ich beneide ihn noch.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 18,
      "text": "Das ist mein zustand. Ich gehe zu bett damit.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    }
  ]
}
