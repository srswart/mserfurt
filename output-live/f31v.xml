<PcGts xmlns="http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15 http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15/pagecontent.xsd"><Metadata><Creator>xl-export</Creator><Created>2026-03-19T00:00:00Z</Created><LastChange>2026-03-19T00:00:00Z</LastChange></Metadata><Page imageFilename="" imageWidth="1000" imageHeight="1000"><TextRegion id="r1" custom="type:paragraph"><Coords points="0,0 1000,0 1000,1000 0,1000" /><TextLine id="l1" custom="register:de"><Coords points="0,0 1000,0 1000,58 0,58" /><Baseline points="0,56 1000,56" /><TextEquiv index="0"><Unicode>gantz stille sitzen und warten, was ich empfinde.</Unicode></TextEquiv></TextLine><TextLine id="l2" custom="register:de"><Coords points="0,58 1000,58 1000,116 0,116" /><Baseline points="0,114 1000,114" /><TextEquiv index="0"><Unicode>Hette es eyne Druckerei in dem Jare 1435 geben, so</Unicode></TextEquiv></TextLine><TextLine id="l3" custom="register:de"><Coords points="0,116 1000,116 1000,174 0,174" /><Baseline points="0,172 1000,172" /><TextEquiv index="0"><Unicode>hette ich nicht mugen thun, das ich getan habe.</Unicode></TextEquiv></TextLine><TextLine id="l4" custom="register:de"><Coords points="0,174 1000,174 1000,232 0,232" /><Baseline points="0,230 1000,230" /><TextEquiv index="0"><Unicode>Die Druckerei machet nicht wider zurecht. Die</Unicode></TextEquiv></TextLine><TextLine id="l5" custom="register:de"><Coords points="0,232 1000,232 1000,290 0,290" /><Baseline points="0,288 1000,288" /><TextEquiv index="0"><Unicode>Druckerei sittet nicht mit dreien möglichen Worten</Unicode></TextEquiv></TextLine><TextLine id="l6" custom="register:de"><Coords points="0,290 1000,290 1000,348 0,348" /><Baseline points="0,346 1000,346" /><TextEquiv index="0"><Unicode>und wählet das, welches sie für wahr hält. Die</Unicode></TextEquiv></TextLine><TextLine id="l7" custom="register:de"><Coords points="0,348 1000,348 1000,406 0,406" /><Baseline points="0,404 1000,404" /><TextEquiv index="0"><Unicode>Druckerei setzet den Text, wie er gegeben ist, und</Unicode></TextEquiv></TextLine><TextLine id="l8" custom="register:de"><Coords points="0,406 1000,406 1000,464 0,464" /><Baseline points="0,462 1000,462" /><TextEquiv index="0"><Unicode>verfertiget ihn genau, den Riß und alles, alle</Unicode></TextEquiv></TextLine><TextLine id="l9" custom="register:de"><Coords points="0,464 1000,464 1000,522 0,522" /><Baseline points="0,520 1000,520" /><TextEquiv index="0"><Unicode>Zweideutigkeit bewahret, das beschädigte Verbum</Unicode></TextEquiv></TextLine><TextLine id="l10" custom="register:de"><Coords points="0,522 1000,522 1000,580 0,580" /><Baseline points="0,578 1000,578" /><TextEquiv index="0"><Unicode>fahrend vorwärts in seiner redlichen Unlesbarkeit</Unicode></TextEquiv></TextLine><TextLine id="l11" custom="register:de"><Coords points="0,580 1000,580 1000,638 0,638" /><Baseline points="0,636 1000,636" /><TextEquiv index="0"><Unicode>für die Gelehrten, daß sie darüber streiten mögen,</Unicode></TextEquiv></TextLine><TextLine id="l12" custom="register:de"><Coords points="0,638 1000,638 1000,696 0,696" /><Baseline points="0,694 1000,694" /><TextEquiv index="0"><Unicode>denn daß ein junger Schreiber in seiner Zelle es</Unicode></TextEquiv></TextLine><TextLine id="l13" custom="register:de"><Coords points="0,696 1000,696 1000,754 0,754" /><Baseline points="0,752 1000,752" /><TextEquiv index="0"><Unicode>still auflöset.</Unicode></TextEquiv></TextLine><TextLine id="l14" custom="register:mixed"><Coords points="0,754 1000,754 1000,812 0,812" /><Baseline points="0,810 1000,810" /><TextEquiv index="0"><Unicode>Mein Sünde erforderte die Handschriftentradition. Es</Unicode></TextEquiv></TextLine><TextLine id="l15" custom="register:mixed"><Coords points="0,812 1000,812 1000,870 0,870" /><Baseline points="0,868 1000,868" /><TextEquiv index="0"><Unicode>bedorfte der langen, langsamen, menschlichen Kette</Unicode></TextEquiv></TextLine><TextLine id="l16" custom="register:mixed"><Coords points="0,870 1000,870 1000,928 0,928" /><Baseline points="0,926 1000,926" /><TextEquiv index="0"><Unicode>von Hütern, da ein iglich Glied ein Mensch ist mit</Unicode></TextEquiv></TextLine><TextLine id="l17" custom="register:mixed"><Coords points="0,928 1000,928 1000,986 0,986" /><Baseline points="0,984 1000,984" /><TextEquiv index="0"><Unicode>Urteil und Mangel und der Macht, zu irren. Die</Unicode></TextEquiv></TextLine></TextRegion></Page></PcGts>