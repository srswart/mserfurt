{
  "id": "f07v",
  "recto_verso": "verso",
  "gathering_position": 7,
  "damage": null,
  "hand_notes": null,
  "section_breaks": [12],
  "vellum_stock": "standard",
  "lines": [
    {
      "number": 1,
      "text": "zu der feder vnd dem pergament vnd tue meins.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 2,
      "text": "Von dem verstehen vnd dem nit-verstehen muß ich noch",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 3,
      "text": "reden, wann es ist das, was mein meister mir gelehret hat,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 4,
      "text": "vnd was ich erst im alter zu glauben angefangen habe.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 5,
      "text": "Er sagte: wenn du verstehst, was du schreibst, schreibst",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 6,
      "text": "du es zu schnell. Das klang damals wie eine dummheit.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 7,
      "text": "Jetzt klingt es wie eine wahrheit. Das verstehen kommt,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 8,
      "text": "wenn man einen text langsam kopiert, viel später als wenn",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 9,
      "text": "man ihn liest. Man meint, beim lesen verstehet man. Aber",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 10,
      "text": "das lesen ist ein gleiten über die oberfläche. Das schreiben",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 11,
      "text": "ist ein graben. Man muß durch jedes wort hindurch.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 12,
      "text": "Ich hab das am deutlichsten erfahren mit dem zweiten brief",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 13,
      "text": "Pauli an die Korinther. Ich schrib ihn in dem sommer des",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 14,
      "text": "jares MCCCCLII, als das haus sehr heiß war vnd alle",
      "register": "mixed",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 15,
      "text": "ungeduldig waren, auch ich. Ich schrib schnell vnd ich",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 16,
      "text": "dachte: ich kenne disen brief. Ich kenne die wort. Ich",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 17,
      "text": "bin damit fertig in einer wochen. Vnd dann kam ich zu",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 18,
      "text": "dem ort, wo Paulus schreibt: virtus in infirmitate perficitur.",
      "register": "mixed",
      "annotations": [{"type": "confidence", "detail": {"score": 0.95}}]
    },
    {
      "number": 19,
      "text": "Die kraft wird vollkommen in der schwachheit. Ich schrib",
      "register": "mixed",
      "annotations": [{"type": "confidence", "detail": {"score": 0.95}}]
    },
    {
      "number": 20,
      "text": "es vnd hielt inne. Ich schrib es nochmals auf einem stück",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 21,
      "text": "pergament für mich selbst vnd legte es unter mein kissen.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 22,
      "text": "Es ist noch da. Das stück pergament. Es ist dünn geworden.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    }
  ]
}
