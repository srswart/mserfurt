<PcGts xmlns="http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15 http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15/pagecontent.xsd"><Metadata><Creator>xl-export</Creator><Created>2026-03-19T00:00:00Z</Created><LastChange>2026-03-19T00:00:00Z</LastChange></Metadata><Page imageFilename="" imageWidth="1000" imageHeight="1000"><TextRegion id="r1" custom="type:paragraph"><Coords points="0,0 1000,0 1000,1000 0,1000" /><TextLine id="l1" custom="register:de"><Coords points="0,0 1000,0 1000,43 0,43" /><Baseline points="0,41 1000,41" /><TextEquiv index="0"><Unicode>Letter gesetzet und bereit, die ganze Seite</Unicode></TextEquiv></TextLine><TextLine id="l2" custom="register:de"><Coords points="0,43 1000,43 1000,86 0,86" /><Baseline points="0,84 1000,84" /><TextEquiv index="0"><Unicode>bestehend als ihr eigen klein Metallreich, ein jedes</Unicode></TextEquiv></TextLine><TextLine id="l3" custom="register:de"><Coords points="0,86 1000,86 1000,129 0,129" /><Baseline points="0,127 1000,127" /><TextEquiv index="0"><Unicode>Wort bereits entschieden, wartend nur auf die</Unicode></TextEquiv></TextLine><TextLine id="l4" custom="register:de"><Coords points="0,129 1000,129 1000,172 0,172" /><Baseline points="0,170 1000,170" /><TextEquiv index="0"><Unicode>Schwärze und den Druck, der es fünfhundert Male ohne</Unicode></TextEquiv></TextLine><TextLine id="l5" custom="register:de"><Coords points="0,172 1000,172 1000,215 0,215" /><Baseline points="0,213 1000,213" /><TextEquiv index="0"><Unicode>Veränderung würde abdrucken, ohne die Einmischung</Unicode></TextEquiv></TextLine><TextLine id="l6" custom="register:de"><Coords points="0,215 1000,215 1000,258 0,258" /><Baseline points="0,256 1000,256" /><TextEquiv index="0"><Unicode>eines einzigen menschlichen Urteils zwischen dem</Unicode></TextEquiv></TextLine><TextLine id="l7" custom="register:de"><Coords points="0,258 1000,258 1000,301 0,301" /><Baseline points="0,299 1000,299" /><TextEquiv index="0"><Unicode>ersten Abdruck und dem letzten.</Unicode></TextEquiv></TextLine><TextLine id="l8" custom="register:de"><Coords points="0,301 1000,301 1000,344 0,344" /><Baseline points="0,342 1000,342" /><TextEquiv index="0"><Unicode>Ich betrachtete es lange Zeit.</Unicode></TextEquiv></TextLine><TextLine id="l9" custom="register:mixed"><Coords points="0,344 1000,344 1000,387 0,387" /><Baseline points="0,385 1000,385" /><TextEquiv index="0"><Unicode>Es was ein blat des heiligen Augustinus, in quo</Unicode></TextEquiv></TextLine><TextLine id="l10" custom="register:mixed"><Coords points="0,387 1000,387 1000,430 0,430" /><Baseline points="0,428 1000,428" /><TextEquiv index="0"><Unicode>venerabilis doctor ecclesiae suae profundissimas</Unicode></TextEquiv></TextLine><TextLine id="l11" custom="register:mixed"><Coords points="0,430 1000,430 1000,473 0,473" /><Baseline points="0,471 1000,471" /><TextEquiv index="0"><Unicode>cogitationes de natura animae et gratia divina</Unicode></TextEquiv></TextLine><TextLine id="l12" custom="register:mixed"><Coords points="0,473 1000,473 1000,516 0,516" /><Baseline points="0,514 1000,514" /><TextEquiv index="0"><Unicode>exposuerat. Die schrift was alt und gebrechlich, die</Unicode></TextEquiv></TextLine><TextLine id="l13" custom="register:mixed"><Coords points="0,516 1000,516 1000,559 0,559" /><Baseline points="0,557 1000,557" /><TextEquiv index="0"><Unicode>tinte verblasset zu einem matter braun, doch noch</Unicode></TextEquiv></TextLine><TextLine id="l14" custom="register:mixed"><Coords points="0,559 1000,559 1000,602 0,602" /><Baseline points="0,600 1000,600" /><TextEquiv index="0"><Unicode>leslich für einen, der mit gedult und andacht sich</Unicode></TextEquiv></TextLine><TextLine id="l15" custom="register:mixed"><Coords points="0,602 1000,602 1000,645 0,645" /><Baseline points="0,643 1000,643" /><TextEquiv index="0"><Unicode>darüber neigete. Quanta reverentia, quanta</Unicode></TextEquiv></TextLine><TextLine id="l16" custom="register:mixed"><Coords points="0,645 1000,645 1000,688 0,688" /><Baseline points="0,686 1000,686" /><TextEquiv index="0"><Unicode>humilitate oportet accedere ad talia scripta, quae</Unicode></TextEquiv></TextLine><TextLine id="l17" custom="register:mixed"><Coords points="0,688 1000,688 1000,731 0,731" /><Baseline points="0,729 1000,729" /><TextEquiv index="0"><Unicode>ab uno ex patribus nostris sanctissimis conscripta</Unicode></TextEquiv></TextLine><TextLine id="l18" custom="register:mixed"><Coords points="0,731 1000,731 1000,774 0,774" /><Baseline points="0,772 1000,772" /><TextEquiv index="0"><Unicode>sunt! Ich hielt das blat mit zitternden henden, denn</Unicode></TextEquiv></TextLine><TextLine id="l19" custom="register:mixed"><Coords points="0,774 1000,774 1000,817 0,817" /><Baseline points="0,815 1000,815" /><TextEquiv index="0"><Unicode>ich wuste wol, daß ich unwürdig was, solche worte zu</Unicode></TextEquiv></TextLine><TextLine id="l20" custom="register:mixed"><Coords points="0,817 1000,817 1000,860 0,860" /><Baseline points="0,858 1000,858" /><TextEquiv index="0"><Unicode>berüren. Sed gratia Dei, quae omnia vincit et omnes</Unicode></TextEquiv></TextLine><TextLine id="l21" custom="register:mixed"><Coords points="0,860 1000,860 1000,903 0,903" /><Baseline points="0,901 1000,901" /><TextEquiv index="0"><Unicode>homines ad se vocat, mihi etiam peccatori viam</Unicode></TextEquiv></TextLine><TextLine id="l22" custom="register:mixed"><Coords points="0,903 1000,903 1000,946 0,946" /><Baseline points="0,944 1000,944" /><TextEquiv index="0"><Unicode>aperuit ad intelligentiam. Die worte leuchteten mir</Unicode></TextEquiv></TextLine><TextLine id="l23" custom="register:mixed"><Coords points="0,946 1000,946 1000,989 0,989" /><Baseline points="0,987 1000,987" /><TextEquiv index="0"><Unicode>auf wie ein licht in der finsternis meiner</Unicode></TextEquiv></TextLine></TextRegion></Page></PcGts>