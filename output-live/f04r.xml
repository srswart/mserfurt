<PcGts xmlns="http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15 http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15/pagecontent.xsd"><Metadata><Creator>xl-export</Creator><Created>2026-03-19T00:00:00Z</Created><LastChange>2026-03-19T00:00:00Z</LastChange></Metadata><Page imageFilename="" imageWidth="1000" imageHeight="1000"><TextRegion id="r1" custom="type:paragraph"><Coords points="0,0 1000,0 1000,1000 0,1000" /><TextLine id="l1" custom="register:de"><Coords points="0,0 1000,0 1000,62 0,62" /><Baseline points="0,60 1000,60" /><TextEquiv index="0"><Unicode>meinen Schreibtisch setzen und werde fortfahren den</Unicode></TextEquiv></TextLine><TextLine id="l2" custom="register:de"><Coords points="0,62 1000,62 1000,124 0,124" /><Baseline points="0,122 1000,122" /><TextEquiv index="0"><Unicode>Psalter, den ich abschreibe für einen Kaufmann zu</Unicode></TextEquiv></TextLine><TextLine id="l3" custom="register:de"><Coords points="0,124 1000,124 1000,186 0,186" /><Baseline points="0,184 1000,184" /><TextEquiv index="0"><Unicode>Franckfurt, der noch nicht weiß, daß er ihn könnte</Unicode></TextEquiv></TextLine><TextLine id="l4" custom="register:de"><Coords points="0,186 1000,186 1000,248 0,248" /><Baseline points="0,246 1000,246" /><TextEquiv index="0"><Unicode>drucken lassen für ein Drittel des Preises. Ich</Unicode></TextEquiv></TextLine><TextLine id="l5" custom="register:de"><Coords points="0,248 1000,248 1000,310 0,310" /><Baseline points="0,308 1000,308" /><TextEquiv index="0"><Unicode>werde es ihm endlich sagen. Ich halte an, daß ich es</Unicode></TextEquiv></TextLine><TextLine id="l6" custom="register:de"><Coords points="0,310 1000,310 1000,372 0,372" /><Baseline points="0,370 1000,370" /><TextEquiv index="0"><Unicode>ihm nicht sage.</Unicode></TextEquiv></TextLine><TextLine id="l7" custom="register:de"><Coords points="0,372 1000,372 1000,434 0,434" /><Baseline points="0,432 1000,432" /><TextEquiv index="0"><Unicode>Ich gedencke, daß ich nicht bereyt bin, es im zu</Unicode></TextEquiv></TextLine><TextLine id="l8" custom="register:de"><Coords points="0,434 1000,434 1000,496 0,496" /><Baseline points="0,494 1000,494" /><TextEquiv index="0"><Unicode>sagen, wan sobald ich es thue, so muß ich im</Unicode></TextEquiv></TextLine><TextLine id="l9" custom="register:de"><Coords points="0,496 1000,496 1000,558 0,558" /><Baseline points="0,556 1000,556" /><TextEquiv index="0"><Unicode>erkleren, warumb er das mein noch begeren sol.</Unicode></TextEquiv></TextLine><TextLine id="l10" custom="register:de"><Coords points="0,558 1000,558 1000,620 0,620" /><Baseline points="0,618 1000,618" /><TextEquiv index="0"><Unicode>I am ready to receive the English text you would</Unicode></TextEquiv></TextLine><TextLine id="l11" custom="register:de"><Coords points="0,620 1000,620 1000,682 0,682" /><Baseline points="0,680 1000,680" /><TextEquiv index="0"><Unicode>like me to translate into Frühneuhochdeutsch (Early</Unicode></TextEquiv></TextLine><TextLine id="l12" custom="register:de"><Coords points="0,682 1000,682 1000,744 0,744" /><Baseline points="0,742 1000,742" /><TextEquiv index="0"><Unicode>New High German) in the Thuringian dialect circa</Unicode></TextEquiv></TextLine><TextLine id="l13" custom="register:de"><Coords points="0,744 1000,744 1000,806 0,806" /><Baseline points="0,804 1000,804" /><TextEquiv index="0"><Unicode>1457. Please provide the English text, and I will</Unicode></TextEquiv></TextLine><TextLine id="l14" custom="register:de"><Coords points="0,806 1000,806 1000,868 0,868" /><Baseline points="0,866 1000,866" /><TextEquiv index="0"><Unicode>translate it according to the specifications you</Unicode></TextEquiv></TextLine><TextLine id="l15" custom="register:de"><Coords points="0,868 1000,868 1000,930 0,930" /><Baseline points="0,928 1000,928" /><TextEquiv index="0"><Unicode>have outlined.</Unicode></TextEquiv></TextLine><TextLine id="l16" custom="register:de"><Coords points="0,930 1000,930 1000,992 0,992" /><Baseline points="0,990 1000,990" /><TextEquiv index="0"><Unicode>Ich verstehe deine Anweisung. Ich bin bereit,</Unicode></TextEquiv></TextLine></TextRegion></Page></PcGts>