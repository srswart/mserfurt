{
  "id": "f12r",
  "recto_verso": "recto",
  "gathering_position": 12,
  "damage": null,
  "hand_notes": null,
  "section_breaks": [8],
  "vellum_stock": "standard",
  "lines": [
    {
      "number": 1,
      "text": "hand, die jetzt schreibt. Das ist eine tröstung, die ich",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 2,
      "text": "mir nit selbst gemacht habe. Sie ist mir gegeben worden,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 3,
      "text": "wie alles, was ich habe. Ich nehme sie dankbar an.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 4,
      "text": "Ich frage mich manchmal: was wird mit den büchern, wenn",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 5,
      "text": "ich gestorben bin? Die bücher, die ich geschrieben hab,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 6,
      "text": "die hier in Erffordt sind vnd anderswo — in Gotha hab",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 7,
      "text": "ich gebracht, vnd in Mühlhausen, vnd einen nach Halberstat.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 8,
      "text": "Jemand wird jene bücher lesen nach mir. Vielleicht bald,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 9,
      "text": "vielleicht in hundert jahren. Ich werde den leser nit kennen.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 10,
      "text": "Der leser wird mich nit kennen. Er wird die hand sehen —",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 11,
      "text": "meine hand — aber er wird nit wissen: Konrad. Er wird",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 12,
      "text": "denken: ein schreiber hat das gemacht, wer auch immer.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 13,
      "text": "Vnd das ist richtig. Das ist, wie es sein soll. Der schreiber",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 14,
      "text": "ist das mittel, nit das ziel. Das text ist das ziel. Das",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 15,
      "text": "wort ist das ziel. Gott ist das ziel. Vnd dem schreiber",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 16,
      "text": "sollte das genügen — sein mittlersein zu sein, sein",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 17,
      "text": "diener-sein, sein nit-sichtbar-sein im werk. Mir genügt",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 18,
      "text": "es — heute. Gestern nit. Morgen vielleicht nit. Aber heute.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 19,
      "text": "Ich habe gelernt, den heute zu nehmen ohne den morgen",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 20,
      "text": "dazu zu fordern. Das hat mir das schreiben gelehret vnd",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 21,
      "text": "das beten zugleich: heute. Heute schreibe ich. Heute bete",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 22,
      "text": "ich. Ob ich morgen schreibe vnd bete, das weiß Gott.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    }
  ]
}
