  "lines": [
    {
      "number": 1,
      "text": "Sechsundzwanzigsten october. Ich habe heute das halbe",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 2,
      "text": "Johannisevangelium fertig geschrieben. Die langen reden",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 3,
      "text": "Christi — sie sind ein meer. Man schreibt sie vnd verliert",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 4,
      "text": "sich darin vnd findet sich wieder vnd verliert sich wieder.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 5,
      "text": "Das ist kein schlechtes verlieren. Es iß das richtige.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 6,
      "text": "Wer sich nit verliert, der findet nit.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 7,
      "text": "Neunundzwanzigsten october. Heute hat es geschneit. Den",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 8,
      "text": "ersten schnee des jahres, früh, vor der none. Ich stand",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 9,
      "text": "am fenster vnd sah zu. Der schnee fällt wie buchstaben,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.95}}]
    },
    {
      "number": 10,
      "text": "jeder einzeln, jeder verschieden, jeder für sich vnd",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 11,
      "text": "alle zusammen ein weißes wort, das kein mensch lesen kan.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 12,
      "text": "Ich hab das lang angesehen. Dann bin ich wieder an den tisch.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 13,
      "text": "Ersten november. Allerseelen morgen. Ich bete heute für",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 14,
      "text": "meinen meister, der mich das schreiben gelehrt hat vnd",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.95}}]
    },
    {
      "number": 15,
      "text": "der vor zwölf jahren gestorben ist, in einem april, als",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 16,
      "text": "ich nit dabei war. Er hat mir nit gesagt, daß er sterben",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 17,
      "text": "würde. Aber das tut man wohl nit. Man stirbt einfach.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 18,
      "text": "Ich bete, daß er eine ruhige hand hat, dort wo er ist.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    }
  ]
}
