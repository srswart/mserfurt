<?xml version='1.0' encoding='utf-8'?>
<PcGts xmlns="http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15 http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15/pagecontent.xsd"><Metadata><Creator>xl-export</Creator><Created>2026-03-19T00:00:00Z</Created><LastChange>2026-03-19T00:00:00Z</LastChange></Metadata><Page imageFilename="" imageWidth="1000" imageHeight="1000"><TextRegion id="r1" custom="type:paragraph"><Coords points="0,0 1000,0 1000,1000 0,1000" /><TextLine id="l1" custom="register:de"><Coords points="0,0 1000,0 1000,43 0,43" /><Baseline points="0,41 1000,41" /><TextEquiv index="0"><Unicode>daz Wissen ist das, dem ich nachschreibe.</Unicode></TextEquiv></TextLine><TextLine id="l2" custom="register:de"><Coords points="0,43 1000,43 1000,86 0,86" /><Baseline points="0,84 1000,84" /><TextEquiv index="0"><Unicode>Alles andere — die Druckerei, der Schüler, den ich</Unicode></TextEquiv></TextLine><TextLine id="l3" custom="register:de"><Coords points="0,86 1000,86 1000,129 0,129" /><Baseline points="0,127 1000,127" /><TextEquiv index="0"><Unicode>verloren habe, die Augen, die mir feilen — das ist</Unicode></TextEquiv></TextLine><TextLine id="l4" custom="register:de"><Coords points="0,129 1000,129 1000,172 0,172" /><Baseline points="0,170 1000,170" /><TextEquiv index="0"><Unicode>nun der Fluß, der sich mir selbst erkläret. Ich</Unicode></TextEquiv></TextLine><TextLine id="l5" custom="register:de"><Coords points="0,172 1000,172 1000,215 0,215" /><Baseline points="0,213 1000,213" /><TextEquiv index="0"><Unicode>versuche zu verstehen, wozu ich gebraucht worden</Unicode></TextEquiv></TextLine><TextLine id="l6" custom="register:de"><Coords points="0,215 1000,215 1000,258 0,258" /><Baseline points="0,256 1000,256" /><TextEquiv index="0"><Unicode>bin, ehe das Wasser ganz dahin fließet und ich dürre</Unicode></TextEquiv></TextLine><TextLine id="l7" custom="register:de"><Coords points="0,258 1000,258 1000,301 0,301" /><Baseline points="0,299 1000,299" /><TextEquiv index="0"><Unicode>am Gestade liegen bleibe, welches kommet, welches</Unicode></TextEquiv></TextLine><TextLine id="l8" custom="register:de"><Coords points="0,301 1000,301 1000,344 0,344" /><Baseline points="0,342 1000,342" /><TextEquiv index="0"><Unicode>vielleicht schon hie ist.</Unicode></TextEquiv></TextLine><TextLine id="l9" custom="register:mixed"><Coords points="0,344 1000,344 1000,387 0,387" /><Baseline points="0,385 1000,385" /><TextEquiv index="0"><Unicode>Ich habe dir mein ganzes Leben lang geschrieben. Ich</Unicode></TextEquiv></TextLine><TextLine id="l10" custom="register:mixed"><Coords points="0,387 1000,387 1000,430 0,430" /><Baseline points="0,428 1000,428" /><TextEquiv index="0"><Unicode>habe ditz nye geschriben.</Unicode></TextEquiv></TextLine><TextLine id="l11" custom="register:de"><Coords points="0,430 1000,430 1000,473 0,473" /><Baseline points="0,471 1000,471" /><TextEquiv index="0"><Unicode>Ich wil anheben mit der neuen Kunst — die Presse,</Unicode></TextEquiv></TextLine><TextLine id="l12" custom="register:de"><Coords points="0,473 1000,473 1000,516 0,516" /><Baseline points="0,514 1000,514" /><TextEquiv index="0"><Unicode>als man sie zu nennen anfenget. Nicht darum, daß sie</Unicode></TextEquiv></TextLine><TextLine id="l13" custom="register:de"><Coords points="0,516 1000,516 1000,559 0,559" /><Baseline points="0,557 1000,557" /><TextEquiv index="0"><Unicode>das Ende der Geschichte ist, sondern darum, daß sie</Unicode></TextEquiv></TextLine><TextLine id="l14" custom="register:de"><Coords points="0,559 1000,559 1000,602 0,602" /><Baseline points="0,600 1000,600" /><TextEquiv index="0"><Unicode>die Geschichte aufgerüttelt hat. Und darum, daß ich</Unicode></TextEquiv></TextLine><TextLine id="l15" custom="register:de"><Coords points="0,602 1000,602 1000,645 0,645" /><Baseline points="0,643 1000,643" /><TextEquiv index="0"><Unicode>das schwerere Ding nicht geradewegs angehen kan. Ich</Unicode></TextEquiv></TextLine><TextLine id="l16" custom="register:de"><Coords points="0,645 1000,645 1000,688 0,688" /><Baseline points="0,686 1000,686" /><TextEquiv index="0"><Unicode>bin ein Schreiber. Ich nahe mich von dem Rande und</Unicode></TextEquiv></TextLine><TextLine id="l17" custom="register:de"><Coords points="0,688 1000,688 1000,731 0,731" /><Baseline points="0,729 1000,729" /><TextEquiv index="0"><Unicode>arbeite mich hinein.</Unicode></TextEquiv></TextLine><TextLine id="l18" custom="register:de"><Coords points="0,731 1000,731 1000,774 0,774" /><Baseline points="0,772 1000,772" /><TextEquiv index="0"><Unicode>Es ist nu ein Maschine zu Mainz — eine Maschine, die</Unicode></TextEquiv></TextLine><TextLine id="l19" custom="register:de"><Coords points="0,774 1000,774 1000,817 0,817" /><Baseline points="0,815 1000,815" /><TextEquiv index="0"><Unicode>in einem Tage das hervorbringet, das ich in vier</Unicode></TextEquiv></TextLine><TextLine id="l20" custom="register:de"><Coords points="0,817 1000,817 1000,860 0,860" /><Baseline points="0,858 1000,858" /><TextEquiv index="0"><Unicode>Monaten hervorbring. Sie setzet Buchstaben in Metall</Unicode></TextEquiv></TextLine><TextLine id="l21" custom="register:de"><Coords points="0,860 1000,860 1000,903 0,903" /><Baseline points="0,901 1000,901" /><TextEquiv index="0"><Unicode>und drucket sie auf das Blat mit einer Kraft, die</Unicode></TextEquiv></TextLine><TextLine id="l22" custom="register:de"><Coords points="0,903 1000,903 1000,946 0,946" /><Baseline points="0,944 1000,944" /><TextEquiv index="0"><Unicode>ich in meinen Füssen gefühlet habe, da ich neben ihr</Unicode></TextEquiv></TextLine><TextLine id="l23" custom="register:de"><Coords points="0,946 1000,946 1000,989 0,989" /><Baseline points="0,987 1000,987" /><TextEquiv index="0"><Unicode>stund. Ich bin neben ihr gestanden. Ich werde dir</Unicode></TextEquiv></TextLine></TextRegion></Page></PcGts>