      "annotations": [
        {
          "type": "confidence",
          "detail": {
            "score": 0.97
          }
        }
      ]
    },
    {
      "number": 8,
      "text": "Ich bin ein Schreiber gewesen dreißig Jar. Ich habe das Wort",
