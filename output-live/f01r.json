      "annotations": [
        {
          "type": "confidence",
          "detail": {
            "score": 0.97
          }
        }
      ]
    },
    {
      "number": 9,
      "text": "abgeschrieben, wie es durch mich gieng — die Psalmen, die",
      "register": "de",
      "annotations": [
        {
          "type": "confidence",
          "detail": {
            "score": 0.97
          }
        }
      ]
    },
    {
      "number": 10,
      "text": "Evangelien, die großen Ausleger, die kleinen — und ich",
      "register": "de",
      "annotations": [
        {
          "type": "confidence",
          "detail": {
            "score": 0.97
          }
        }
      ]
    },
    {
      "number": 11,
      "text": "verstand frühe, daß meine Rolle in disem war, was eines",
      "register": "de",
      "annotations": [
        {
          "type": "confidence",
          "detail": {
            "score": 0.97
          }
        }
      ]
    },
    {
      "number": 12,
      "text": "Kiesels Rolle ist in einem Fluße. Der Strom beweget sich.",
      "register": "de",
      "annotations": [
        {
          "type": "confidence",
          "detail": {
            "score": 0.97
          }
        }
      ]
    },
    {
      "number": 13,
      "text": "Der Kiesel lenket ihn nicht. Der Kiesel wird getragen,",
      "register": "de",
      "annotations": [
        {
          "type": "confidence",
          "detail": {
            "score": 0.97
          }
        }
      ]
    },
    {
