  "lines": [
    {
      "number": 1,
      "text": "Sechzehnten november, anno Domini MCCCCLVII. Ich lege",
      "register": "mixed",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 2,
      "text": "die feder nieder. Nit für immer — morgen nehme ich sie",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 3,
      "text": "wieder, für das amt, für die brüder, für das wort, das",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 4,
      "text": "durch mich gehet vnd das nit meins ist. Aber für dises",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 5,
      "text": "buch lege ich sie nieder. Es ist gesagt, was ich sagen",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 6,
      "text": "kunnte. Es ist nit alles. Es ist nit genug. Aber es ist",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 7,
      "text": "wahr, soweit ein mensch wahr sein kann. Daran halte ich.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 8,
      "text": "Gott weiß das übrige. Er hat immer das übrige gewußt.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 9,
      "text": "Explicit hic liber. Scriptus per manum Conradi, canonici",
      "register": "mixed",
      "annotations": [{"type": "confidence", "detail": {"score": 0.93}}]
    },
    {
      "number": 10,
      "text": "secularis in domo Augustinensium Erfordiensis, anno",
      "register": "mixed",
      "annotations": [{"type": "confidence", "detail": {"score": 0.93}}]
    },
    {
      "number": 11,
      "text": "Domini millesimo quadringentesimo quinquagesimo septimo,",
      "register": "mixed",
      "annotations": [{"type": "confidence", "detail": {"score": 0.93}}]
    },
    {
      "number": 12,
      "text": "in mense novembris, sine laude propria, sed ad laudem Dei",
      "register": "mixed",
      "annotations": [{"type": "confidence", "detail": {"score": 0.93}}]
    },
    {
      "number": 13,
      "text": "omnipotentis et gloriosae virginis Mariae. Orate pro eo.",
      "register": "mixed",
      "annotations": [{"type": "confidence", "detail": {"score": 0.93}}]
    },
    {
      "number": 14,
      "text": "Vnd wan ihr ihn nit kennt — er war ein schreiber, nit",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 15,
      "text": "mehr vnd nit weniger, vnd er hat dreißig jahre lang das",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 16,
      "text": "wort durch sich hindurchgelassen vnd dabei — das iß das",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 17,
      "text": "wunder, das er nit erwartet hatte — das wort hat auch ihn",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 18,
      "text": "hindurchgelassen.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.95}}]
    }
  ]
}
