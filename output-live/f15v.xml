<PcGts xmlns="http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15 http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15/pagecontent.xsd"><Metadata><Creator>xl-export</Creator><Created>2026-03-19T00:00:00Z</Created><LastChange>2026-03-19T00:00:00Z</LastChange></Metadata><Page imageFilename="" imageWidth="1000" imageHeight="1000"><TextRegion id="r1" custom="type:paragraph"><Coords points="0,0 1000,0 1000,1000 0,1000" /><TextLine id="l1" custom="register:de"><Coords points="0,0 1000,0 1000,58 0,58" /><Baseline points="0,56 1000,56" /><TextEquiv index="0"><Unicode>eingefüget. Ob er aber völlich bedacht hat, was er</Unicode></TextEquiv></TextLine><TextLine id="l2" custom="register:de"><Coords points="0,58 1000,58 1000,116 0,116" /><Baseline points="0,114 1000,114" /><TextEquiv index="0"><Unicode>hat außgelassen — das ist ein ander frage."</Unicode></TextEquiv></TextLine><TextLine id="l3" custom="register:de"><Coords points="0,116 1000,116 1000,174 0,174" /><Baseline points="0,172 1000,172" /><TextEquiv index="0"><Unicode>Es ist die einige Frage.</Unicode></TextEquiv></TextLine><TextLine id="l4" custom="register:de"><Coords points="0,174 1000,174 1000,232 0,232" /><Baseline points="0,230 1000,230" /><TextEquiv index="0"><Unicode>Er gos danne wein aus, von irgent woher, wie die</Unicode></TextEquiv></TextLine><TextLine id="l5" custom="register:de"><Coords points="0,232 1000,232 1000,290 0,290" /><Baseline points="0,288 1000,288" /><TextEquiv index="0"><Unicode>männer in den werckstetten allewege wein zu haben</Unicode></TextEquiv></TextLine><TextLine id="l6" custom="register:de"><Coords points="0,290 1000,290 1000,348 0,348" /><Baseline points="0,346 1000,346" /><TextEquiv index="0"><Unicode>pflegen, und wir stunden zusammen bei dem fenster,</Unicode></TextEquiv></TextLine><TextLine id="l7" custom="register:de"><Coords points="0,348 1000,348 1000,406 0,406" /><Baseline points="0,404 1000,404" /><TextEquiv index="0"><Unicode>das auf die gasse siehet. Er sprach danne etwas, das</Unicode></TextEquiv></TextLine><TextLine id="l8" custom="register:de"><Coords points="0,406 1000,406 1000,464 0,464" /><Baseline points="0,462 1000,462" /><TextEquiv index="0"><Unicode>ich seitdem immer und immer wider in meinem sinne</Unicode></TextEquiv></TextLine><TextLine id="l9" custom="register:de"><Coords points="0,464 1000,464 1000,522 0,522" /><Baseline points="0,520 1000,520" /><TextEquiv index="0"><Unicode>wende — oder ich habe in es sagen gemacht, welches</Unicode></TextEquiv></TextLine><TextLine id="l10" custom="register:de"><Coords points="0,522 1000,522 1000,580 0,580" /><Baseline points="0,578 1000,578" /><TextEquiv index="0"><Unicode>das gedechtnisse mit den menschen tuet, die wir</Unicode></TextEquiv></TextLine><TextLine id="l11" custom="register:de"><Coords points="0,580 1000,580 1000,638 0,638" /><Baseline points="0,636 1000,636" /><TextEquiv index="0"><Unicode>nicht lassen können zu bestreiten, und ich weiss nun</Unicode></TextEquiv></TextLine><TextLine id="l12" custom="register:de"><Coords points="0,638 1000,638 1000,696 0,696" /><Baseline points="0,694 1000,694" /><TextEquiv index="0"><Unicode>nicht mehr, welche teil sein sind und welche teil</Unicode></TextEquiv></TextLine><TextLine id="l13" custom="register:de"><Coords points="0,696 1000,696 1000,754 0,754" /><Baseline points="0,752 1000,752" /><TextEquiv index="0"><Unicode>ich in den wochen des wiederholens hinzu getan habe.</Unicode></TextEquiv></TextLine><TextLine id="l14" custom="register:de"><Coords points="0,754 1000,754 1000,812 0,812" /><Baseline points="0,810 1000,810" /><TextEquiv index="0"><Unicode>Ich werde es schreiben, wie es in meinem</Unicode></TextEquiv></TextLine><TextLine id="l15" custom="register:de"><Coords points="0,812 1000,812 1000,870 0,870" /><Baseline points="0,868 1000,868" /><TextEquiv index="0"><Unicode>gedechtnisse stehet, und Ir möget die nehe richten.</Unicode></TextEquiv></TextLine><TextLine id="l16" custom="register:de"><Coords points="0,870 1000,870 1000,928 0,928" /><Baseline points="0,926 1000,926" /><TextEquiv index="0"><Unicode>Er sprach: „Du verstehest, daß ditz geschehen</Unicode></TextEquiv></TextLine><TextLine id="l17" custom="register:de"><Coords points="0,928 1000,928 1000,986 0,986" /><Baseline points="0,984 1000,984" /><TextEquiv index="0"><Unicode>wirdet. Nicht die Verstümmelung — die Verstümmelung</Unicode></TextEquiv></TextLine></TextRegion></Page></PcGts>