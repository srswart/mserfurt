  "section_breaks": [1, 6, 11],
  "vellum_stock": "irregular",
  "lines": [
    {
      "number": 1,
      "text": "hatte zwischen uns zweien. Requiescat in pace, bruder.",
      "register": "mixed",
      "annotations": [{"type": "confidence", "detail": {"score": 0.95}}]
    },
    {
      "number": 2,
      "text": "Du hast jeden morgen gebetet vnd jeden morgen in meinem",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 3,
      "text": "buch gelesen, vnd ich hab dich nit einmal gefragt, ob",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 4,
      "text": "es dir gut gefiel. Das ist mein fehler, nit das fehlende e.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 5,
      "text": "Das iß, worum ich Buße tue. Um das nit-fragen.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 6,
      "text": "Zwanzigsten october. Ich habe heute einen jungen mann",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 7,
      "text": "gesehen im hof, der schreibt mit einem stöckchen in den",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 8,
      "text": "staub. Er weiß nit, was er schreibt. Aber er schreibt.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 9,
      "text": "Das ist der anfang. Bevor man weiß, was das schreiben ist,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 10,
      "text": "tut man es. Ich hab das vergessen. Er hat es noch.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 11,
      "text": "Dreyundzwanzigsten october. Der gelehrte bruder hat mich",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 12,
      "text": "heute gefragt, was ich schreibe — das hier. Ich sagte:",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 13,
      "text": "nichts, nur notizen. Er nickte. Er weiß, daß ich lüge,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 14,
      "text": "vnd er fragt nit nach. Das ist die freundschaft: man",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 15,
      "text": "läßt dem anderen seinen raum, auch wenn man weiß, daß",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 16,
      "text": "etwas darin ist, das man nit zeigen will. Ich bin ihm",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 17,
      "text": "dankbar für diesen raum. Er gibt ihn mir jeden tag.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 18,
      "text": "Das ist mehr wert als ich ihm je sagen werde.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    }
  ]
}
