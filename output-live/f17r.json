  "damage": null,
  "hand_notes": "hand notably hurried; several letters show compressed ascenders; appears to be last regular session before colophon",
  "section_breaks": [1, 7, 13],
  "vellum_stock": "irregular",
  "lines": [
    {
      "number": 1,
      "text": "Elften november. Heute sah ich meine hand im wasser. Ich",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 2,
      "text": "wusch die tinte ab vnd da war sie, im becken, die hand,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 3,
      "text": "alt vnd voll tintenflecken. Dreißig jahre auf ihr. Man",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 4,
      "text": "sieht dem alter nit an, ob es gutt gelebt hat. Man sieht",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 5,
      "text": "nur das alter. Gott sieht das andere. Das iß sein amt.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 6,
      "text": "Ich bin zufrieden, daß es seins ist vnd nit meins.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 7,
      "text": "Dreizehnten november. Ein gedanke, der mich nit läßt:",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 8,
      "text": "das schreiben ist das einzige, das ich getan habe, wobei",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 9,
      "text": "ich vergessen habe, daß ich Konrad bin. Beim beten weiß",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 10,
      "text": "ich, daß ich Konrad bin, vnd das stört manchmal. Beim",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 11,
      "text": "schreiben vergesse ich Konrad. Ich bin nur die hand. Das",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 12,
      "text": "ist vielleicht das nächste, was ich dem beten je kam.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 13,
      "text": "Fünfzehnten november. Letzte anmerkung, bevor ich abschließe.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 14,
      "text": "Ich habe in dreißig jahren niemals einen text verbessert,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 15,
      "text": "den ich abschrieb. Das ist das gesetz des schreibers: du",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 16,
      "text": "bist nit der auctor. Ich hab das einmal gebrochen — das",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 17,
      "text": "ist der erste moment in diesem buch, der im winter dreißig",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 18,
      "text": "vnd fünf. Darüber hab ich nun genug gesagt. Es ist genug.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    }
  ]
}
