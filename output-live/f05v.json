  "lines": [
    {
      "number": 1,
      "text": "gegeben habe. Das ist, gelehrter gesagt: die sünde gegen",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 2,
      "text": "das pergament ist eine art unaufmerksamkeit, vnd die",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 3,
      "text": "unaufmerksamkeit ist eine art hochmut — der schreiber",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 4,
      "text": "denkt, er ist größer als der stoff, der ihn trägt. Er ist",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 5,
      "text": "es nit. Ich bin es nit. Das pergament ist älter als ich",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 6,
      "text": "vnd wird länger dauern als ich. Was ich schreibe, bleibt",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 7,
      "text": "darin, vnd was ich falsch schreibe, bleibt auch darin.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 8,
      "text": "Man kann schaben vnd kratzen — aber der abdruck bleibt.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 9,
      "text": "Ich hab das oft gesehen bey alten büchern: man hat etwas",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 10,
      "text": "ausgebessert, vnd die rasur ist sauber vnd das neue wort",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 11,
      "text": "stehet richtig da — aber in dem richtigen licht, in dem",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 12,
      "text": "schrägen licht des abends, sieht man das alte wort noch",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 13,
      "text": "hindurch. Wie ein geist. Das alte wort stirbt nit ganz.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 14,
      "text": "Ist das trost oder schrecken? Beides, glaube ich. Trost,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 15,
      "text": "weil das geschriebene nit verloren gehet, auch wenn man",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 16,
      "text": "es auslöscht. Schrecken, weil auch die fehler nit verloren",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 17,
      "text": "gehen. Vnd nun muß ich reden von dem, was schwerer ist",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 18,
      "text": "als das pergament vnd leichter als das gebet, von dem",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 19,
      "text": "ort, wo das schreiben aufhört vnd die stille anfängt,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 20,
      "text": "vnd diese stille ist nit leer sunder voll von dem, was",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 21,
      "text": "man nit geschrieben hat, vnd der heilige Geist, der sagt:",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 22,
      "text": "spiritus ubi vult spirat, et vocem eius audis, sed nescis",
      "register": "mixed",
      "annotations": [{"type": "confidence", "detail": {"score": 0.95}}]
    }
  ]
}
