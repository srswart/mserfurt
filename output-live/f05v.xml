<?xml version='1.0' encoding='utf-8'?>
<PcGts xmlns="http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15 http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15/pagecontent.xsd"><Metadata><Creator>xl-export</Creator><Created>2026-03-19T00:00:00Z</Created><LastChange>2026-03-19T00:00:00Z</LastChange></Metadata><Page imageFilename="" imageWidth="1000" imageHeight="1000"><TextRegion id="r1" custom="type:paragraph"><Coords points="0,0 1000,0 1000,1000 0,1000" /><TextLine id="l1" custom="register:de"><Coords points="0,0 1000,0 1000,55 0,55" /><Baseline points="0,53 1000,53" /><TextEquiv index="0"><Unicode>angefangen, mich selber als die person zu gedencken,</Unicode></TextEquiv></TextLine><TextLine id="l2" custom="register:de"><Coords points="0,55 1000,55 1000,110 0,110" /><Baseline points="0,108 1000,108" /><TextEquiv index="0"><Unicode>die itzund zwischen ihm und dem, das er werden</Unicode></TextEquiv></TextLine><TextLine id="l3" custom="register:de"><Coords points="0,110 1000,110 1000,165 0,165" /><Baseline points="0,163 1000,163" /><TextEquiv index="0"><Unicode>solde, stunde.</Unicode></TextEquiv></TextLine><TextLine id="l4" custom="register:mixed"><Coords points="0,165 1000,165 1000,220 0,220" /><Baseline points="0,218 1000,218" /><TextEquiv index="0"><Unicode>I understand. I'm ready to translate English text</Unicode></TextEquiv></TextLine><TextLine id="l5" custom="register:mixed"><Coords points="0,220 1000,220 1000,275 0,275" /><Baseline points="0,273 1000,273" /><TextEquiv index="0"><Unicode>into Frühneuhochdeutsch (Early New High German) in</Unicode></TextEquiv></TextLine><TextLine id="l6" custom="register:mixed"><Coords points="0,275 1000,275 1000,330 0,330" /><Baseline points="0,328 1000,328" /><TextEquiv index="0"><Unicode>the Thuringian dialect circa 1457, following all the</Unicode></TextEquiv></TextLine><TextLine id="l7" custom="register:mixed"><Coords points="0,330 1000,330 1000,385 0,385" /><Baseline points="0,383 1000,383" /><TextEquiv index="0"><Unicode>specifications you've outlined. Please provide the</Unicode></TextEquiv></TextLine><TextLine id="l8" custom="register:mixed"><Coords points="0,385 1000,385 1000,440 0,440" /><Baseline points="0,438 1000,438" /><TextEquiv index="0"><Unicode>English text you'd like translated, and I'll deliver</Unicode></TextEquiv></TextLine><TextLine id="l9" custom="register:mixed"><Coords points="0,440 1000,440 1000,495 0,495" /><Baseline points="0,493 1000,493" /><TextEquiv index="0"><Unicode>only the translated text without explanation or</Unicode></TextEquiv></TextLine><TextLine id="l10" custom="register:mixed"><Coords points="0,495 1000,495 1000,550 0,550" /><Baseline points="0,548 1000,548" /><TextEquiv index="0"><Unicode>commentary. Ich wil, daß du sihest, daß ich</Unicode></TextEquiv></TextLine><TextLine id="l11" custom="register:mixed"><Coords points="0,550 1000,550 1000,605 0,605" /><Baseline points="0,603 1000,603" /><TextEquiv index="0"><Unicode>vorsichtig bin.</Unicode></TextEquiv></TextLine><TextLine id="l12" custom="register:de"><Coords points="0,605 1000,605 1000,660 0,660" /><Baseline points="0,658 1000,658" /><TextEquiv index="0"><Unicode>Ich habe Peter nicht geliebet, wie ein Mann einen</Unicode></TextEquiv></TextLine><TextLine id="l13" custom="register:de"><Coords points="0,660 1000,660 1000,715 0,715" /><Baseline points="0,713 1000,713" /><TextEquiv index="0"><Unicode>Knaben nicht soll lieben. Ich will das klar gesaget</Unicode></TextEquiv></TextLine><TextLine id="l14" custom="register:de"><Coords points="0,715 1000,715 1000,770 0,770" /><Baseline points="0,768 1000,768" /><TextEquiv index="0"><Unicode>haben, denn ich weiß wol, wie solche Berichte</Unicode></TextEquiv></TextLine><TextLine id="l15" custom="register:de"><Coords points="0,770 1000,770 1000,825 0,825" /><Baseline points="0,823 1000,823" /><TextEquiv index="0"><Unicode>mißverstanden werden mögen, und denn die</Unicode></TextEquiv></TextLine><TextLine id="l16" custom="register:de"><Coords points="0,825 1000,825 1000,880 0,880" /><Baseline points="0,878 1000,878" /><TextEquiv index="0"><Unicode>Bekenntnisse selbst sind also mißverstanden worden,</Unicode></TextEquiv></TextLine><TextLine id="l17" custom="register:de"><Coords points="0,880 1000,880 1000,935 0,935" /><Baseline points="0,933 1000,933" /><TextEquiv index="0"><Unicode>und Augustinus hat bessers verdient denn das, und</Unicode></TextEquiv></TextLine><TextLine id="l18" custom="register:de"><Coords points="0,935 1000,935 1000,990 0,990" /><Baseline points="0,988 1000,988" /><TextEquiv index="0"><Unicode>Peter auch, und ich auch, mit deiner Erlaubnis. Was</Unicode></TextEquiv></TextLine></TextRegion></Page></PcGts>