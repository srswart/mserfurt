  "hand_notes": null,
  "section_breaks": [],
  "vellum_stock": "standard",
  "lines": [
    {
      "number": 1,
      "text": "Der abt hatte angst vor dem feuer. Das ist billig. Kerzen",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 2,
      "text": "in dem scriptorium — das ist ein altes streitgespräch,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 3,
      "text": "vnd ich hab meinen teil darin getragen. Die bücher brennen",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 4,
      "text": "leicht. Pergament ist trocken. Tinte brennt nit, aber",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 5,
      "text": "pergament brennt, vnd das wort, das auf dem pergament",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 6,
      "text": "stehet, brennt mit. Das weiß jeder, der je ein haus hat",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 7,
      "text": "brennen sehen. Der abt sagte: Konrad, bring die kerze",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 8,
      "text": "weiter vom tisch. Ich sagte: Vater, dann sehe ich nit.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 9,
      "text": "Er sagte: dann schreibe tagsüber. Ich sagte: tagsüber",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 10,
      "text": "bin ich nit so gut. Er sah mich lange an vnd ging dann.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 11,
      "text": "Das war der abt — er verstand, daß man einem schreiber",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 12,
      "text": "seine wege läßt, auch wenn man nit verstehet, was die",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 13,
      "text": "wege bedeuten. Das ist ein gutt abt. Er ist nun tot, vnd",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 14,
      "text": "ich bete für ihn täglich. Für seine geduld mit mir.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 15,
      "text": "Ein anderer bruder — ich will seinen namen nit schreiben,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 16,
      "text": "wan es schickt sich nit — sagte mir einmal: du schreibest",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 17,
      "text": "wie einer, der weinet. Ich weiß nit, was er meinte,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 18,
      "text": "aber ich habe das aufgehoben in mir. Vielleicht ist es",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 19,
      "text": "ein lob vnd vielleicht ist es eine klage. Es kann beides",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 20,
      "text": "sein. Schreiben wie einer, der weinet — das ist nit das",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 21,
      "text": "schlechteste. Christus hat geweinet. Augustinus hat",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 22,
      "text": "geweinet. Das weinen ist nit gegen das wort, sondern",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    }
  ]
}
