{
  "id": "f03r",
  "recto_verso": "recto",
  "gathering_position": 3,
  "damage": null,
  "hand_notes": null,
  "section_breaks": [12],
  "vellum_stock": "standard",
  "lines": [
    {
      "number": 1,
      "text": "Hieronymus hab ich auch geschrieben, vnd er ist ein anderer",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 2,
      "text": "meister als David. David weinet vnd singet zugleich.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 3,
      "text": "Hieronymus ist trocken wie das pergament in dem sommer,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 4,
      "text": "er redet mit einer stimme, die kein mitleiden hat, sunder",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 5,
      "text": "allein die warhafftigkeit will, vnd das ist seine große",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 6,
      "text": "tugend vnd sein großes fehler zugleich. Ich hab das gespürt",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 7,
      "text": "an der feder — wan man Hieronymus schreibet, so sitzet",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 8,
      "text": "man gerade, man schreibet gerade, die buchstaben wollen",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 9,
      "text": "sich aufrecht halten. Bey dem Psalter schreibet man",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 10,
      "text": "mit gebeugtem rücken, als ob man weinet oder betet.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 11,
      "text": "Der leib weiß, was der kopff noch nit erkannt hat.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 12,
      "text": "Aber von Augustinus muß ich reden, wan er ist mir der",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 13,
      "text": "nächste, obwol er mir der fremdeste war in den ersten",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 14,
      "text": "jaren. Ich hab seine Confessiones geschrieben — das ganze",
      "register": "mixed",
      "annotations": [{"type": "confidence", "detail": {"score": 0.95}}]
    },
    {
      "number": 15,
      "text": "buch — vor sieben jaren, in einem winter. Es hat mich",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 16,
      "text": "zwey monate gekostet. Ich schrib täglich von der früh",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 17,
      "text": "bis zur non, vnd die wort giengen durch mich wie wasser",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 18,
      "text": "durch ein sieb. Sie kamen an vnd giengen weiter vnd",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 19,
      "text": "ich blieb zurück mit dem pergament vnd der tinte vnd",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 20,
      "text": "der wunderbaren frage: wie kan einer sein eigenes hertz",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 21,
      "text": "aufschreiben vnd es nit dabei verlieren? Augustinus hat",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 22,
      "text": "das gewußt. Ich weiß es noch nit. Vnd doch — ich schreibe.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    }
  ]
}
