{
  "id": "f08r",
  "recto_verso": "recto",
  "gathering_position": 8,
  "damage": null,
  "hand_notes": null,
  "section_breaks": [],
  "vellum_stock": "standard",
  "lines": [
    {
      "number": 1,
      "text": "Ich hab oft einen bruder gefragt — nit seinen namen —",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 2,
      "text": "er ist ein gelehrter mann vnd leset sehr viel — ich fragte:",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 3,
      "text": "verstehet du die wort von Paulus besser als ich, der sie",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 4,
      "text": "abgeschrieben hat? Er lachte vnd sagte: nein, Konrad,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 5,
      "text": "ich verstehe sie vielleicht anders, aber nit besser.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 6,
      "text": "Das hat mir wohlgetan. Er ist ein guter bruder, der",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 7,
      "text": "gelehrte. Er weiß, daß das wissen nit das letzte ist.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 8,
      "text": "Dann gibt es einen anderen — auch ohne namen — der sehr",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 9,
      "text": "fromm ist vnd der mir manchmal beim schreiben zuschaut,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 10,
      "text": "vnd er betet dabei, still für sich, als ob das schreiben",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 11,
      "text": "selbst eine liturgie wäre, die man begleiten muß. Das",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 12,
      "text": "habe ich nie gesagt vnd werde es nie sagen, aber ich",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 13,
      "text": "bin dankbar dafür. Man arbeitet besser, wenn jemand betet.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 14,
      "text": "Das klingt abergläubisch vnd ist es vielleicht. Aber es",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 15,
      "text": "ist auch wahr, vnd die warhafftigkeit ist das erste.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 16,
      "text": "Ein dritter bruder — dieser iß jung, er iß kaum zwanzig",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 17,
      "text": "jahre — hat mir einmal meine feder genommen vnd probiert,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 18,
      "text": "einen buchstaben zu schreiben. Er hat es nit gut gemacht.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 19,
      "text": "Aber er hat es so aufmerksam versucht vnd so ernsthaftig,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 20,
      "text": "daß ich mußte umwenden, damit er mein gesicht nit sah.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 21,
      "text": "Das schreiben ist ernst. Der junge bruder hat das gespürt,",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 22,
      "text": "ohne daß ihm jemand gesagt hätte, was es bedeutet. Das",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    }
  ]
}
