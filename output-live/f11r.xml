<?xml version='1.0' encoding='utf-8'?>
<PcGts xmlns="http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15 http://schema.primaresearch.org/PAGE/gts/pagecontent/2019-07-15/pagecontent.xsd"><Metadata><Creator>xl-export</Creator><Created>2026-03-19T00:00:00Z</Created><LastChange>2026-03-19T00:00:00Z</LastChange></Metadata><Page imageFilename="" imageWidth="1000" imageHeight="1000"><TextRegion id="r1" custom="type:paragraph"><Coords points="0,0 1000,0 1000,1000 0,1000" /><TextLine id="l1" custom="register:de"><Coords points="0,0 1000,0 1000,43 0,43" /><Baseline points="0,41 1000,41" /><TextEquiv index="0"><Unicode>Die Werkstatt war lauter, denn ich sie in meinem</Unicode></TextEquiv></TextLine><TextLine id="l2" custom="register:de"><Coords points="0,43 1000,43 1000,86 0,86" /><Baseline points="0,84 1000,84" /><TextEquiv index="0"><Unicode>Gedächtnis behalten hatte. Eine Druckerei in vollem</Unicode></TextEquiv></TextLine><TextLine id="l3" custom="register:de"><Coords points="0,86 1000,86 1000,129 0,129" /><Baseline points="0,127 1000,127" /><TextEquiv index="0"><Unicode>Werke — ich erfuhr hernach, daß sie zweihundert</Unicode></TextEquiv></TextLine><TextLine id="l4" custom="register:de"><Coords points="0,129 1000,129 1000,172 0,172" /><Baseline points="0,170 1000,170" /><TextEquiv index="0"><Unicode>Exemplare eines Kanonrechtsummarium vollendeten, ein</Unicode></TextEquiv></TextLine><TextLine id="l5" custom="register:de"><Coords points="0,172 1000,172 1000,215 0,215" /><Baseline points="0,213 1000,213" /><TextEquiv index="0"><Unicode>Text so dürre und geschäftlich, daß ich mich</Unicode></TextEquiv></TextLine><TextLine id="l6" custom="register:de"><Coords points="0,215 1000,215 1000,258 0,258" /><Baseline points="0,256 1000,256" /><TextEquiv index="0"><Unicode>kurtzlich getröstet fühlte; gewiß war dies alles,</Unicode></TextEquiv></TextLine><TextLine id="l7" custom="register:de"><Coords points="0,258 1000,258 1000,301 0,301" /><Baseline points="0,299 1000,299" /><TextEquiv index="0"><Unicode>wozu die Maschine taugte, rechtliche Summaria,</Unicode></TextEquiv></TextLine><TextLine id="l8" custom="register:de"><Coords points="0,301 1000,301 1000,344 0,344" /><Baseline points="0,342 1000,342" /><TextEquiv index="0"><Unicode>Texte, die ihrer Namenlosigkeit würdig waren, Texte,</Unicode></TextEquiv></TextLine><TextLine id="l9" custom="register:de"><Coords points="0,344 1000,344 1000,387 0,387" /><Baseline points="0,385 1000,385" /><TextEquiv index="0"><Unicode>die kein Schreiber je geliebet hatte — und der</Unicode></TextEquiv></TextLine><TextLine id="l10" custom="register:de"><Coords points="0,387 1000,387 1000,430 0,430" /><Baseline points="0,428 1000,428" /><TextEquiv index="0"><Unicode>Schall war rhythmisch und schwer, der Arm der Presse</Unicode></TextEquiv></TextLine><TextLine id="l11" custom="register:de"><Coords points="0,430 1000,430 1000,473 0,473" /><Baseline points="0,471 1000,471" /><TextEquiv index="0"><Unicode>sank herab und die Druckplatte schlug auf und das</Unicode></TextEquiv></TextLine><TextLine id="l12" custom="register:de"><Coords points="0,473 1000,473 1000,516 0,516" /><Baseline points="0,514 1000,514" /><TextEquiv index="0"><Unicode>ganze Gebäude nahm den Stoß auf wie eine geschlagene</Unicode></TextEquiv></TextLine><TextLine id="l13" custom="register:de"><Coords points="0,516 1000,516 1000,559 0,559" /><Baseline points="0,557 1000,557" /><TextEquiv index="0"><Unicode>Glocke, die nicht erklinget, sondern nur dicker</Unicode></TextEquiv></TextLine><TextLine id="l14" custom="register:de"><Coords points="0,559 1000,559 1000,602 0,602" /><Baseline points="0,600 1000,600" /><TextEquiv index="0"><Unicode>wird.</Unicode></TextEquiv></TextLine><TextLine id="l15" custom="register:de"><Coords points="0,602 1000,602 1000,645 0,645" /><Baseline points="0,643 1000,643" /><TextEquiv index="0"><Unicode>Wilhelm sahe mich vnd neicte das haupt, on alle</Unicode></TextEquiv></TextLine><TextLine id="l16" custom="register:de"><Coords points="0,645 1000,645 1000,688 0,688" /><Baseline points="0,686 1000,686" /><TextEquiv index="0"><Unicode>verwunderung. Ich was, wie es schein, ein</Unicode></TextEquiv></TextLine><TextLine id="l17" custom="register:de"><Coords points="0,688 1000,688 1000,731 0,731" /><Baseline points="0,729 1000,729" /><TextEquiv index="0"><Unicode>gewonlicher worden.</Unicode></TextEquiv></TextLine><TextLine id="l18" custom="register:de"><Coords points="0,731 1000,731 1000,774 0,774" /><Baseline points="0,772 1000,772" /><TextEquiv index="0"><Unicode>Demetrios stund an eyme Setzrahmen neben der hindern</Unicode></TextEquiv></TextLine><TextLine id="l19" custom="register:de"><Coords points="0,774 1000,774 1000,817 0,817" /><Baseline points="0,815 1000,815" /><TextEquiv index="0"><Unicode>Wand, neben eynem jungen Setzer, des Namen ich</Unicode></TextEquiv></TextLine><TextLine id="l20" custom="register:de"><Coords points="0,817 1000,817 1000,860 0,860" /><Baseline points="0,858 1000,858" /><TextEquiv index="0"><Unicode>hernach erfuhr, daß er Hans hieß. Er selber setzet</Unicode></TextEquiv></TextLine><TextLine id="l21" custom="register:de"><Coords points="0,860 1000,860 1000,903 0,903" /><Baseline points="0,901 1000,901" /><TextEquiv index="0"><Unicode>nicht mit eynen Henden. Er las aus eynem Manuskript</Unicode></TextEquiv></TextLine><TextLine id="l22" custom="register:de"><Coords points="0,903 1000,903 1000,946 0,946" /><Baseline points="0,944 1000,944" /><TextEquiv index="0"><Unicode>— nicht sein eigen, sondern eyne Werckstatt-Kopie —</Unicode></TextEquiv></TextLine><TextLine id="l23" custom="register:de"><Coords points="0,946 1000,946 1000,989 0,989" /><Baseline points="0,987 1000,987" /><TextEquiv index="0"><Unicode>und verglich es mit eyner Form, die Hans gesetzet</Unicode></TextEquiv></TextLine></TextRegion></Page></PcGts>