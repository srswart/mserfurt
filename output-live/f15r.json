{
  "id": "f15r",
  "recto_verso": "recto",
  "gathering_position": 15,
  "damage": null,
  "hand_notes": "ink slightly thinner on this leaf; vellum surface uneven at upper right",
  "section_breaks": [1, 7, 13],
  "vellum_stock": "irregular",
  "lines": [
    {
      "number": 1,
      "text": "Zwölften october. Heute hab ich angefangen, das Evangelium",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 2,
      "text": "Johannis zu schreiben. In principio erat Verbum. Im anfang",
      "register": "mixed",
      "annotations": [{"type": "confidence", "detail": {"score": 0.95}}]
    },
    {
      "number": 3,
      "text": "war das wort. Ich habe das schon oft geschrieben, vnd",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 4,
      "text": "es ist heute anders als je. Das wort iß am anfang. Nit",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 5,
      "text": "das schweigen, nit die stille — das wort. Das ist die",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 6,
      "text": "erste antwort auf alles, was ich in diesem buch gefragt habe.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 7,
      "text": "Vierzehenten october. Es regnet. Die Gera iß braun.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 8,
      "text": "Ich habe heute nit gutt geschrieben. Die tinte ist zu",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 9,
      "text": "dünn, oder das pergament nimmt sie nit an, oder meine",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 10,
      "text": "hand war nit da, wo sie sein sollte. Ich weiß es nit.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.95}}]
    },
    {
      "number": 11,
      "text": "Manche tage sind so. Man tut das richtige vnd es kommt",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 12,
      "text": "nit richtig heraus. Das iß nit der tag, der fehlt. Ich bin es.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 13,
      "text": "Achtzehnten october. Ich bete seit einer stunde für den",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 14,
      "text": "bruder Dietrich, der gestorben ist. Er hat meinen psalter",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 15,
      "text": "mitgenommen in den tod. Den psalter mit dem fehlenden e.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 16,
      "text": "Er hat täglich darin gelesen. Vielleicht hat er den fehler",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 17,
      "text": "nit gemerkt. Vielleicht hat er ihn gemerkt vnd mir vergeben.",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    },
    {
      "number": 18,
      "text": "Ich bitte Gott, daß er ihm vergeben hat, wer immer recht",
      "register": "de",
      "annotations": [{"type": "confidence", "detail": {"score": 0.97}}]
    }
  ]
}
