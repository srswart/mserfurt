# ScribeHand orchestration environment (copy to diagnostics/scribehand.env)
# Source before running steps, or let orchestrate.py load it automatically.
#
#   cp docs/scribehand-orchestration.env.example diagnostics/scribehand.env
#   # edit paths, then:
#   uv run python scripts/scribehand/orchestrate.py env-check

REPO_ROOT=.

# Upstream model clones (outside this repo)
ONEDM_ROOT=${HOME}/src/One-DM
DIFFUSIONPEN_ROOT=${HOME}/src/DiffusionPen

# Fine-tuned checkpoints (set after step_4)
ONEDM_CKPT=${HOME}/src/One-DM/ckpt/onedm_bastarda_v1.pt
ONEDM_TRAINING_REPORT=${HOME}/src/One-DM/ckpt/training_report.json
DIFFUSIONPEN_CKPT=${HOME}/src/DiffusionPen/ckpt/diffusionpen_bastarda_v1
DIFFUSIONPEN_TRAINING_REPORT=${HOME}/src/DiffusionPen/ckpt/training_report.json

# Anchor data (set when ready)
ANCHOR_DIR=
ANCHOR_WORDS_DIR=
REFERENCE_PAGE=

# Optional: faster HuggingFace downloads (or run `huggingface-cli login`)
# HF_TOKEN=
